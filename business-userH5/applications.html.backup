<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>我的申请</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; background: #f5f5f5; min-height: 100vh; }
        .header { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 15px; display: flex; align-items: center; }
        .header h1 { font-size: 18px; flex: 1; }
        .back { color: white; text-decoration: none; font-size: 14px; }
        .filter { display: flex; gap: 8px; padding: 10px 15px; background: white; overflow-x: auto; border-bottom: 1px solid #f0f0f0; }
        .filter::-webkit-scrollbar { display: none; }
        .filter-item { padding: 6px 14px; border-radius: 15px; font-size: 12px; white-space: nowrap; background: #f0f0f0; color: #666; cursor: pointer; flex-shrink: 0; transition: all .2s; }
        .filter-item.active { background: #667eea; color: white; }
        .list { padding: 10px; }
        .item { background: white; border-radius: 12px; padding: 15px; margin-bottom: 10px; cursor: pointer; transition: box-shadow .2s; box-shadow: 0 1px 4px rgba(0,0,0,.05); }
        .item:active { box-shadow: 0 2px 10px rgba(102,126,234,.2); }
        .item-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; gap: 8px; }
        .item-title { font-size: 15px; font-weight: 500; color: #333; flex: 1; line-height: 1.4; }
        .item-status { font-size: 11px; padding: 3px 8px; border-radius: 10px; flex-shrink: 0; margin-top: 2px; }
        .status-pending { background: #fff3e0; color: #f57c00; }
        .status-processing { background: #e3f2fd; color: #1976d2; }
        .status-completed { background: #e8f5e9; color: #388e3c; }
        .status-rejected { background: #ffebee; color: #d32f2f; }
        .status-cancelled { background: #f5f5f5; color: #999; }
        .item-meta { display: flex; gap: 10px; font-size: 12px; color: #bbb; margin-top: 4px; }
        .item-type { display: inline-flex; align-items: center; gap: 3px; font-size: 12px; color: #666; background: #f5f5f5; padding: 2px 8px; border-radius: 8px; }
        /* 加载更多 */
        .load-more { text-align: center; padding: 16px; }
        .load-more-btn { padding: 10px 28px; background: white; border: 1px solid #667eea; color: #667eea; border-radius: 20px; font-size: 14px; cursor: pointer; }
        .load-more-btn:active { background: #667eea; color: white; }
        .load-more-btn:disabled { opacity: .5; cursor: not-allowed; }
        .empty { text-align: center; padding: 60px 20px; color: #bbb; }
        .empty-icon { font-size: 48px; margin-bottom: 12px; }
        .empty-tip { font-size: 14px; margin-bottom: 8px; }
        .empty-sub { font-size: 12px; color: #ddd; }
        /* FAB */
        .fab { position: fixed; bottom: 30px; right: 20px; width: 56px; height: 56px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 28px; text-decoration: none; box-shadow: 0 4px 14px rgba(102,126,234,.5); z-index: 50; }
        .fab:active { transform: scale(0.96); }
        /* 顶部统计条 */
        .stat-bar { background: white; padding: 8px 15px; display: flex; gap: 16px; font-size: 12px; color: #999; border-bottom: 1px solid #f0f0f0; }
        .stat-bar span { color: #667eea; font-weight: 600; }
    </style>
</head>
<body>
    <div class="header">
        <a href="javascript:void(0)" class="back" onclick="goBack()">← 返回</a>
        <h1>我的申请</h1>
        <span></span>
    </div>

    <!-- 状态筛选 -->
    <div class="filter" id="filterRow">
        <div class="filter-item active" data-status="">全部</div>
        <div class="filter-item" data-status="pending">🕐 待处理</div>
        <div class="filter-item" data-status="processing">⚙️ 处理中</div>
        <div class="filter-item" data-status="completed">✅ 已完成</div>
        <div class="filter-item" data-status="rejected">❌ 已拒绝</div>
        <div class="filter-item" data-status="cancelled">🚫 已撤销</div>
    </div>

    <!-- 统计条 -->
    <div class="stat-bar" id="statBar" style="display:none">
        共 <span id="totalCount">0</span> 条记录
    </div>

    <div class="list" id="list"><div class="empty"><div class="empty-icon">⏳</div><div class="empty-tip">加载中...</div></div></div>

    <!-- 加载更多 -->
    <div class="load-more" id="loadMoreArea" style="display:none">
        <button class="load-more-btn" id="loadMoreBtn" onclick="loadMore()">加载更多</button>
    </div>

    <a href="javascript:void(0)" class="fab" onclick="goTo('application_create.html')">+</a>

    <script>
        var TYPE_MAP = {repair:'🔧 报修', booking:'📅 预约', complaint:'📝 投诉', consult:'💬 咨询', other:'📋 其他'};
        var STATUS_TEXT = {pending:'待处理', processing:'处理中', completed:'已完成', rejected:'已拒绝', cancelled:'已撤销'};

        var urlParams = new URLSearchParams(location.search);
        var token = urlParams.get('access_token');
        var isdev = urlParams.get('isdev') || '0';
        if (token) { localStorage.setItem('user_token', token); localStorage.setItem('user_isdev', isdev); }
        else { token = localStorage.getItem('user_token'); isdev = localStorage.getItem('user_isdev') || '0'; }
        if (!token) { document.body.innerHTML = '<div class="empty">请先登录</div>'; throw new Error('No token'); }

        var currentStatus = '';
        var currentPage = 1;
        var pageSize = 15;
        var totalCount = 0;
        var allItems = [];
        var loading = false;

        function goTo(url) {
            var sep = url.indexOf('?') >= 0 ? '&' : '?';
            location.href = url + sep + 'access_token=' + encodeURIComponent(token) + '&isdev=' + isdev;
        }
        function goBack() { goTo('index.html'); }

        function getStatusClass(s) { return 'item-status status-' + (s || 'pending'); }

        function renderItems(items, append) {
            var html = items.map(function(item) {
                var typeText = TYPE_MAP[item.app_type] || item.app_type || '';
                var statusText = STATUS_TEXT[item.status] || item.status;
                var dateStr = (item.created_at || '').substring(0, 16);
                return '<div class="item" onclick="goTo(\'application_detail.html?id=' + item.id + '\')">'
                    + '<div class="item-header">'
                    + '<span class="item-title">' + (item.title || '') + '</span>'
                    + '<span class="' + getStatusClass(item.status) + '">' + statusText + '</span>'
                    + '</div>'
                    + '<div class="item-meta">'
                    + '<span class="item-type">' + typeText + '</span>'
                    + '<span>' + dateStr + '</span>'
                    + '</div>'
                    + '</div>';
            }).join('');
            if (append) {
                document.getElementById('list').innerHTML += html;
            } else {
                document.getElementById('list').innerHTML = html || '<div class="empty"><div class="empty-icon">📭</div><div class="empty-tip">暂无申请记录</div><div class="empty-sub">点击右下角 + 提交新申请</div></div>';
            }
        }

        async function loadList(reset) {
            if (loading) return;
            if (reset) { currentPage = 1; allItems = []; }
            loading = true;
            var btn = document.getElementById('loadMoreBtn');
            if (btn) { btn.disabled = true; btn.textContent = '加载中...'; }

            if (currentPage === 1) {
                document.getElementById('list').innerHTML = '<div class="empty"><div class="empty-icon">⏳</div><div class="empty-tip">加载中...</div></div>';
                document.getElementById('loadMoreArea').style.display = 'none';
                document.getElementById('statBar').style.display = 'none';
            }

            var url = '/api/user/applications?page=' + currentPage + '&page_size=' + pageSize
                + (currentStatus ? '&status=' + currentStatus : '')
                + '&access_token=' + encodeURIComponent(token) + '&isdev=' + isdev;
            try {
                var res = await fetch(url);
                var data = await res.json();
                if (data.success && data.data) {
                    var items = data.data.items || [];
                    totalCount = data.data.total || 0;
                    var pages = data.data.pages || 1;
                    allItems = allItems.concat(items);

                    // 更新统计条
                    document.getElementById('totalCount').textContent = totalCount;
                    document.getElementById('statBar').style.display = totalCount > 0 ? 'flex' : 'none';

                    if (currentPage === 1) {
                        renderItems(allItems, false);
                    } else {
                        renderItems(items, true);
                    }

                    // 控制"加载更多"按钮
                    if (currentPage < pages) {
                        document.getElementById('loadMoreArea').style.display = 'block';
                        if (btn) { btn.disabled = false; btn.textContent = '加载更多 (' + allItems.length + '/' + totalCount + ')'; }
                    } else {
                        document.getElementById('loadMoreArea').style.display = 'none';
                    }
                }
            } catch(e) {
                if (currentPage === 1) document.getElementById('list').innerHTML = '<div class="empty"><div class="empty-icon">⚠️</div><div class="empty-tip">加载失败，请重试</div></div>';
            }
            loading = false;
        }

        function loadMore() {
            currentPage++;
            loadList(false);
        }

        // 筛选标签点击
        document.querySelectorAll('.filter-item').forEach(function(el) {
            el.addEventListener('click', function() {
                document.querySelectorAll('.filter-item').forEach(function(e) { e.classList.remove('active'); });
                el.classList.add('active');
                currentStatus = el.dataset.status;
                loadList(true);
            });
        });

        loadList(true);
    </script>
</body>
</html>
