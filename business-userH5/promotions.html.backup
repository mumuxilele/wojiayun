<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>限时促销 - 社区服务</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; min-height: 100vh; padding-bottom: 30px; }

        .header { background: linear-gradient(135deg, #ff4e50, #f9d423); color: white; padding: 15px; display: flex; align-items: center; position: sticky; top: 0; z-index: 50; }
        .header h1 { font-size: 18px; flex: 1; text-align: center; font-weight: 700; }
        .back { color: white; font-size: 20px; text-decoration: none; padding: 4px 8px; }

        /* 类型筛选 */
        .type-bar { display: flex; background: white; border-bottom: 1px solid #f0f0f0; overflow-x: auto; position: sticky; top: 52px; z-index: 40; }
        .type-bar::-webkit-scrollbar { display: none; }
        .type-item { padding: 12px 18px; font-size: 13px; color: #666; cursor: pointer; white-space: nowrap; border-bottom: 2px solid transparent; flex-shrink: 0; }
        .type-item.active { color: #ff4e50; border-bottom-color: #ff4e50; font-weight: 600; }

        /* 倒计时横幅 */
        .countdown-banner { background: linear-gradient(135deg, #ff4e50, #fc913a); color: white; padding: 12px 15px; display: flex; align-items: center; justify-content: space-between; }
        .banner-left { display: flex; align-items: center; gap: 8px; }
        .banner-icon { font-size: 22px; }
        .banner-title { font-size: 15px; font-weight: 700; }
        .banner-sub { font-size: 11px; opacity: .85; margin-top: 2px; }
        .countdown { display: flex; gap: 4px; align-items: center; }
        .cd-block { background: rgba(0,0,0,.25); padding: 4px 8px; border-radius: 6px; font-size: 16px; font-weight: 700; min-width: 32px; text-align: center; }
        .cd-sep { font-weight: 700; font-size: 16px; }

        /* 活动卡片 */
        .list { padding: 12px 15px; }
        .promo-card { background: white; border-radius: 14px; margin-bottom: 14px; overflow: hidden; box-shadow: 0 3px 12px rgba(0,0,0,.08); position: relative; }
        .promo-card.seckill { border: 2px solid #ff4e50; }
        .promo-card.full_reduce { border: 2px solid #2196F3; }
        .promo-card.discount { border: 2px solid #9C27B0; }

        /* 活动类型标签 */
        .type-badge { position: absolute; top: 10px; right: 10px; padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; color: white; }
        .type-badge.seckill { background: #ff4e50; }
        .type-badge.full_reduce { background: #2196F3; }
        .type-badge.discount { background: #9C27B0; }

        /* 活动头 */
        .promo-head { display: flex; align-items: center; gap: 10px; padding: 14px 15px 10px; }
        .promo-icon { font-size: 30px; width: 48px; height: 48px; background: #fff5f5; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .promo-icon.full_reduce { background: #e3f2fd; }
        .promo-icon.discount { background: #f3e5f5; }
        .promo-name { font-size: 16px; font-weight: 700; color: #222; }
        .promo-desc { font-size: 12px; color: #999; margin-top: 3px; }

        /* 优惠详情 */
        .promo-detail { margin: 0 15px 12px; background: #fff8f8; border-radius: 10px; padding: 12px; }
        .promo-detail.full_reduce { background: #e3f2fd; }
        .promo-detail.discount { background: #f3e5f5; }

        .detail-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
        .detail-row:last-child { margin-bottom: 0; }
        .detail-label { font-size: 12px; color: #666; }
        .detail-value { font-size: 14px; font-weight: 700; color: #ff4e50; }
        .detail-value.blue { color: #2196F3; }
        .detail-value.purple { color: #9C27B0; }

        /* 进度条（秒杀库存） */
        .stock-bar { margin: 0 15px 12px; }
        .stock-label { display: flex; justify-content: space-between; font-size: 12px; color: #999; margin-bottom: 4px; }
        .stock-label .hot { color: #ff4e50; font-weight: 600; }
        .progress-bg { background: #f0f0f0; border-radius: 4px; height: 6px; overflow: hidden; }
        .progress-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, #ff4e50, #fc913a); transition: width .3s; }

        /* 时间 */
        .time-row { display: flex; align-items: center; gap: 6px; padding: 8px 15px; font-size: 12px; color: #999; border-top: 1px solid #f5f5f5; }
        .time-icon { font-size: 14px; }

        /* 底部按钮 */
        .action-bar { padding: 10px 15px 14px; display: flex; gap: 10px; align-items: center; }
        .tag-used { font-size: 11px; color: #999; }
        .btn-use { flex: 1; background: linear-gradient(135deg, #ff4e50, #fc913a); color: white; border: none; border-radius: 22px; padding: 12px; font-size: 14px; font-weight: 600; cursor: pointer; }
        .btn-use.full_reduce { background: linear-gradient(135deg, #2196F3, #21CBF3); }
        .btn-use.discount { background: linear-gradient(135deg, #9C27B0, #E91E63); }
        .btn-use:disabled { background: #ccc; cursor: not-allowed; }
        .btn-use:active:not(:disabled) { transform: scale(.97); }

        /* 空状态 */
        .empty { text-align: center; padding: 80px 20px; color: #bbb; }
        .empty-icon { font-size: 60px; margin-bottom: 16px; }
        .loading { text-align: center; padding: 60px; color: #999; }

        /* 模态框 */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.5); z-index: 200; }
        .modal-overlay.show { display: flex; align-items: flex-end; }
        .modal { background: white; border-radius: 20px 20px 0 0; padding: 24px 20px; width: 100%; max-height: 70vh; overflow-y: auto; }
        .modal-title { font-size: 18px; font-weight: 700; margin-bottom: 16px; text-align: center; }
        .modal-close { float: right; font-size: 22px; color: #999; cursor: pointer; margin-top: -4px; }
        .calc-input { width: 100%; border: 2px solid #e0e0e0; border-radius: 10px; padding: 12px; font-size: 16px; outline: none; margin-bottom: 12px; }
        .calc-input:focus { border-color: #ff4e50; }
        .calc-result { background: #fff5f5; border-radius: 10px; padding: 14px; margin-bottom: 14px; }
        .calc-row { display: flex; justify-content: space-between; font-size: 14px; padding: 4px 0; }
        .calc-saved { color: #ff4e50; font-weight: 700; font-size: 16px; }
        .btn-goto { width: 100%; background: linear-gradient(135deg, #ff4e50, #fc913a); color: white; border: none; border-radius: 22px; padding: 14px; font-size: 15px; font-weight: 600; cursor: pointer; }
        .btn-goto:active { transform: scale(.98); }
    </style>
</head>
<body>
    <div class="header">
        <a class="back" id="backLink" href="index.html">←</a>
        <h1>🔥 限时促销</h1>
    </div>

    <div class="type-bar">
        <div class="type-item active" data-type="all" onclick="switchType('all', this)">全部活动</div>
        <div class="type-item" data-type="seckill" onclick="switchType('seckill', this)">⚡ 秒杀</div>
        <div class="type-item" data-type="full_reduce" onclick="switchType('full_reduce', this)">💰 满减</div>
        <div class="type-item" data-type="discount" onclick="switchType('discount', this)">🏷️ 折扣</div>
    </div>

    <div id="listWrap">
        <div class="loading">加载中...</div>
    </div>

    <!-- 优惠计算弹窗 -->
    <div class="modal-overlay" id="calcModal" onclick="closeCalc(event)">
        <div class="modal" onclick="event.stopPropagation()">
            <div class="modal-title">
                <span id="calcTitle">计算优惠</span>
                <span class="modal-close" onclick="closeCalc()">×</span>
            </div>
            <div style="font-size:13px;color:#999;margin-bottom:12px">输入商品金额，预估优惠后价格</div>
            <input type="number" class="calc-input" id="calcAmount" placeholder="请输入原价（元）" oninput="calcPreview()">
            <div class="calc-result" id="calcResult" style="display:none">
                <div class="calc-row"><span>原价</span><span id="rOriginal">-</span></div>
                <div class="calc-row"><span>优惠金额</span><span id="rSaved" class="calc-saved">-</span></div>
                <div class="calc-row" style="border-top:1px solid #fdd;padding-top:8px;margin-top:4px;font-weight:700"><span>实付金额</span><span id="rFinal" style="color:#ff4e50;font-size:18px">-</span></div>
            </div>
            <button class="btn-goto" onclick="goShopping()">去商城选购 →</button>
        </div>
    </div>

<script>
var urlParams = new URLSearchParams(location.search);
var token = urlParams.get('access_token') || localStorage.getItem('user_token');
var isdev = urlParams.get('isdev') || localStorage.getItem('user_isdev') || '0';
var BASE = '';
var currentType = 'all';
var currentPromo = null;

// 修正返回链接
document.getElementById('backLink').href = 'index.html' + (token ? '?access_token=' + token + '&isdev=' + isdev : '');

function api(path) { return BASE + path + '?access_token=' + encodeURIComponent(token || '') + '&isdev=' + isdev; }
function goTo(page) { location.href = page + (token ? '?access_token=' + token + '&isdev=' + isdev : ''); }

var TYPE_LABELS = { 'seckill': '⚡ 秒杀', 'full_reduce': '💰 满减', 'discount': '🏷️ 折扣' };
var TYPE_ICONS = { 'seckill': '⚡', 'full_reduce': '💰', 'discount': '🎉' };

function switchType(type, el) {
    currentType = type;
    document.querySelectorAll('.type-item').forEach(function(t) { t.classList.remove('active'); });
    el.classList.add('active');
    loadList();
}

async function loadList() {
    var wrap = document.getElementById('listWrap');
    wrap.innerHTML = '<div class="loading">加载中...</div>';
    if (!token) {
        wrap.innerHTML = '<div class="empty"><div class="empty-icon">🔒</div><div>请先登录查看促销活动</div></div>';
        return;
    }
    try {
        var url = api('/api/user/promotions') + (currentType !== 'all' ? '&type=' + currentType : '');
        var r = await fetch(url);
        var d = await r.json();
        var list = (d.data || []);
        if (!list.length) {
            wrap.innerHTML = '<div class="empty"><div class="empty-icon">🎁</div><div>暂无活动，敬请期待</div></div>';
            return;
        }
        // 渲染
        var html = '<div class="list">';
        list.forEach(function(p) {
            var type = p.promo_type;
            var typeLabel = TYPE_LABELS[type] || type;
            var typeIcon = TYPE_ICONS[type] || '🎉';
            var endTime = p.end_time ? new Date(p.end_time) : null;
            var timeStr = endTime ? '活动截止：' + formatTime(endTime) : '';
            var canUse = p.can_use;
            var usedTip = !canUse ? ('已使用' + p.user_used_count + '次（上限' + p.per_limit + '）') : '';

            html += '<div class="promo-card ' + type + '">';
            html += '<span class="type-badge ' + type + '">' + typeLabel + '</span>';

            // 活动头
            html += '<div class="promo-head">';
            html += '<div class="promo-icon ' + type + '">' + typeIcon + '</div>';
            html += '<div><div class="promo-name">' + escHtml(p.promo_name) + '</div>';
            if (p.description) html += '<div class="promo-desc">' + escHtml(p.description) + '</div>';
            html += '</div></div>';

            // 优惠详情块
            html += '<div class="promo-detail ' + type + '">';
            if (type === 'seckill') {
                html += '<div class="detail-row"><span class="detail-label">秒杀价</span><span class="detail-value">¥' + Number(p.seckill_price || 0).toFixed(2) + '</span></div>';
                var remaining = p.remaining_stock || 0;
                html += '<div class="detail-row"><span class="detail-label">剩余库存</span><span class="detail-value">' + remaining + ' 件</span></div>';
            } else if (type === 'full_reduce') {
                html += '<div class="detail-row"><span class="detail-label">活动规则</span><span class="detail-value blue">满¥' + Number(p.min_amount || 0).toFixed(0) + ' 减¥' + Number(p.reduce_amount || 0).toFixed(0) + '</span></div>';
            } else if (type === 'discount') {
                var rate = Number(p.discount_rate || 1) * 10;
                html += '<div class="detail-row"><span class="detail-label">折扣力度</span><span class="detail-value purple">' + rate.toFixed(1) + ' 折</span></div>';
            }
            if (p.per_limit > 0) {
                html += '<div class="detail-row"><span class="detail-label">每人限用</span><span class="detail-label">' + p.per_limit + ' 次</span></div>';
            }
            html += '</div>';

            // 秒杀库存进度
            if (type === 'seckill' && p.total_stock > 0) {
                var soldPct = Math.min(100, Math.max(5, (1 - (p.remaining_stock || 0) / p.total_stock) * 100));
                html += '<div class="stock-bar">';
                html += '<div class="stock-label"><span class="hot">🔥 抢购中</span><span>已抢 ' + soldPct.toFixed(0) + '%</span></div>';
                html += '<div class="progress-bg"><div class="progress-fill" style="width:' + soldPct + '%"></div></div>';
                html += '</div>';
            }

            // 时间
            if (timeStr) {
                html += '<div class="time-row"><span class="time-icon">⏰</span>' + escHtml(timeStr) + '</div>';
            }

            // 操作栏
            html += '<div class="action-bar">';
            if (usedTip) html += '<span class="tag-used">' + escHtml(usedTip) + '</span>';
            var btnClass = 'btn-use ' + type;
            if (!canUse) btnClass += '" disabled';
            html += '<button class="' + btnClass + '" onclick="openCalc(' + JSON.stringify(p).replace(/"/g, '&quot;') + ')">立即使用</button>';
            html += '</div>';

            html += '</div>';
        });
        html += '</div>';
        wrap.innerHTML = html;
    } catch(e) {
        wrap.innerHTML = '<div class="empty"><div class="empty-icon">⚠️</div><div>加载失败，请刷新重试</div></div>';
    }
}

function openCalc(promo) {
    currentPromo = promo;
    document.getElementById('calcTitle').textContent = promo.promo_name;
    document.getElementById('calcAmount').value = '';
    document.getElementById('calcResult').style.display = 'none';
    document.getElementById('calcModal').classList.add('show');
}

function closeCalc(e) {
    if (e && e.target !== document.getElementById('calcModal')) return;
    document.getElementById('calcModal').classList.remove('show');
    currentPromo = null;
}

async function calcPreview() {
    if (!currentPromo) return;
    var amount = parseFloat(document.getElementById('calcAmount').value);
    if (!amount || amount <= 0) {
        document.getElementById('calcResult').style.display = 'none';
        return;
    }
    try {
        var r = await fetch(api('/api/user/promotions/calc'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ promo_id: currentPromo.id, amount: amount })
        });
        var d = await r.json();
        if (d.success) {
            var data = d.data;
            document.getElementById('rOriginal').textContent = '¥' + data.original_amount.toFixed(2);
            document.getElementById('rSaved').textContent = '-¥' + data.saved_amount.toFixed(2);
            document.getElementById('rFinal').textContent = '¥' + data.final_amount.toFixed(2);
            document.getElementById('calcResult').style.display = 'block';
        }
    } catch(e) {}
}

function goShopping() {
    closeCalc();
    goTo('products.html');
}

function formatTime(d) {
    var pad = function(n) { return n < 10 ? '0' + n : n; };
    return d.getMonth()+1 + '/' + d.getDate() + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
}

function escHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

loadList();
</script>
</body>
</html>
