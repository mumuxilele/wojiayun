<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>我的订单</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; background: #f5f5f5; min-height: 100vh; padding-bottom: 20px; }
        .header { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 15px; display: flex; align-items: center; position: sticky; top: 0; z-index: 50; }
        .header h1 { font-size: 18px; flex: 1; text-align: center; }
        .back { color: white; font-size: 20px; text-decoration: none; padding: 4px 8px; }
        .filter { display: flex; gap: 0; background: white; border-bottom: 1px solid #f0f0f0; position: sticky; top: 52px; z-index: 40; overflow-x: auto; }
        .filter::-webkit-scrollbar { display: none; }
        .filter-item { padding: 11px 14px; font-size: 13px; white-space: nowrap; color: #666; cursor: pointer; border-bottom: 2px solid transparent; flex-shrink: 0; }
        .filter-item.active { color: #667eea; border-bottom-color: #667eea; font-weight: 600; }
        .list { padding: 10px; }
        .item { background: white; border-radius: 12px; padding: 0; margin-bottom: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.05); }
        .item-head { display: flex; justify-content: space-between; align-items: center; padding: 12px 15px; border-bottom: 1px solid #f5f5f5; }
        .item-no { font-size: 12px; color: #999; }
        .item-status { font-size: 12px; padding: 3px 10px; border-radius: 12px; font-weight: 500; }
        .s-pending { background: #fff3e0; color: #f57c00; }
        .s-paid { background: #e3f2fd; color: #1976d2; }
        .s-shipped { background: #e8eaf6; color: #3f51b5; }
        .s-completed { background: #e8f5e9; color: #388e3c; }
        .s-cancelled { background: #f5f5f5; color: #9e9e9e; }
        .s-refunding { background: #fff8e1; color: #f57f17; }
        .s-refunded { background: #fce4ec; color: #c62828; }
        .countdown-bar { margin: 10px 15px 4px; padding: 10px 12px; border-radius: 10px; display: flex; justify-content: space-between; align-items: center; gap: 10px; background: #fff7e6; color: #d46b08; }
        .countdown-bar.urgent { background: #fff1f0; color: #cf1322; }
        .countdown-bar.expired { background: #fafafa; color: #999; }
        .countdown-title { font-size: 12px; font-weight: 600; }
        .countdown-sub { font-size: 11px; opacity: 0.9; margin-top: 3px; }
        .countdown-time { font-size: 16px; font-weight: 700; flex-shrink: 0; }
        .product-list { padding: 8px 15px; }
        .product-row { display: flex; align-items: center; gap: 10px; padding: 6px 0; border-bottom: 1px solid #f9f9f9; }
        .product-row:last-child { border-bottom: none; }
        .prod-img { width: 50px; height: 50px; border-radius: 6px; background: #f5f5f5; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 20px; }
        .prod-img img { width: 100%; height: 100%; object-fit: cover; }
        .prod-info { flex: 1; min-width: 0; }
        .prod-name { font-size: 13px; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .prod-price { font-size: 12px; color: #999; margin-top: 2px; }
        .prod-qty { font-size: 12px; color: #999; flex-shrink: 0; }
        .logistics-bar { background: #f0f4ff; margin: 0 15px 8px; border-radius: 8px; padding: 10px 12px; display: flex; align-items: center; gap: 8px; }
        .logistics-icon { font-size: 18px; }
        .logistics-text { flex: 1; min-width: 0; }
        .logistics-title { font-size: 12px; font-weight: 600; color: #3f51b5; }
        .logistics-no { font-size: 11px; color: #666; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .amount-bar { display: flex; justify-content: flex-end; align-items: center; padding: 10px 15px; gap: 4px; }
        .amount-label { font-size: 13px; color: #666; }
        .amount-value { font-size: 16px; font-weight: 700; color: #f57c00; }
        .action-bar { display: flex; justify-content: flex-end; gap: 8px; padding: 10px 15px; border-top: 1px solid #f5f5f5; flex-wrap: wrap; }
        .btn { padding: 7px 16px; border-radius: 20px; font-size: 13px; cursor: pointer; border: none; font-weight: 500; }
        .btn-outline { background: white; color: #666; border: 1px solid #ddd; }
        .btn-primary { background: linear-gradient(135deg, #667eea, #764ba2); color: white; }
        .btn-danger { background: white; color: #f44336; border: 1px solid #f44336; }
        .btn-warn { background: white; color: #f57c00; border: 1px solid #f57c00; }
        .btn:active { transform: scale(.96); }
        .empty { text-align: center; padding: 60px 20px; color: #bbb; }
        .empty-icon { font-size: 48px; margin-bottom: 10px; }
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.5); z-index: 200; }
        .modal-overlay.show { display: flex; align-items: flex-end; }
        .modal { background: white; border-radius: 16px 16px 0 0; padding: 20px; width: 100%; }
        .modal-title { font-size: 16px; font-weight: 600; margin-bottom: 16px; text-align: center; }
        .modal-label { font-size: 13px; color: #666; margin-bottom: 6px; }
        .modal-textarea { width: 100%; border: 1px solid #e0e0e0; border-radius: 8px; padding: 10px; font-size: 13px; resize: none; outline: none; }
        .modal-textarea:focus { border-color: #667eea; }
        .modal-btns { display: flex; gap: 10px; margin-top: 16px; }
        .modal-btns .btn { flex: 1; text-align: center; }
        .rating-stars { display: flex; gap: 8px; justify-content: center; margin: 12px 0; }
        .rating-stars .star { font-size: 28px; cursor: pointer; color: #ddd; transition: color .2s; }
        .rating-stars .star.active { color: #ffc107; }
    </style>
</head>
<body>
<div class="header">
    <a href="javascript:history.back()" class="back">‹</a>
    <h1>我的订单</h1>
    <span style="width:32px"></span>
</div>

<div class="filter" id="filterTabs">
    <div class="filter-item active" data-status="">全部</div>
    <div class="filter-item" data-status="pending">待支付</div>
    <div class="filter-item" data-status="paid">已支付</div>
    <div class="filter-item" data-status="shipped">已发货</div>
    <div class="filter-item" data-status="completed">已完成</div>
    <div class="filter-item" data-status="refunding">退款中</div>
    <div class="filter-item" data-status="refunded">已退款</div>
    <div class="filter-item" data-status="cancelled">已取消</div>
</div>

<div class="list" id="list"><div class="empty"><div class="empty-icon">⏳</div><p>加载中...</p></div></div>

<div class="modal-overlay" id="refundModal" onclick="closeRefundModal(event)">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-title">申请退款</div>
        <div class="modal-label">退款原因（必填）</div>
        <textarea class="modal-textarea" id="refundReason" rows="3" placeholder="请描述退款原因..."></textarea>
        <div class="modal-btns">
            <button class="btn btn-outline" onclick="closeRefundModal()">取消</button>
            <button class="btn btn-primary" onclick="submitRefund()">提交申请</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="reviewModal" onclick="closeReviewModal(event)">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-title">评价订单</div>
        <div class="modal-label">评分</div>
        <div class="rating-stars" id="ratingStars">
            <span class="star" data-rating="1">★</span>
            <span class="star" data-rating="2">★</span>
            <span class="star" data-rating="3">★</span>
            <span class="star" data-rating="4">★</span>
            <span class="star" data-rating="5">★</span>
        </div>
        <div class="modal-label">评价内容（选填）</div>
        <textarea class="modal-textarea" id="reviewContent" rows="3" placeholder="分享您的购物体验..."></textarea>
        <div class="modal-label" style="margin-top:10px">匿名评价</div>
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#666;cursor:pointer">
            <input type="checkbox" id="reviewAnonymous"> 不显示我的昵称
        </label>
        <div class="modal-btns">
            <button class="btn btn-outline" onclick="closeReviewModal()">取消</button>
            <button class="btn btn-primary" onclick="submitReview()">提交评价</button>
        </div>
    </div>
</div>

<script>
var urlParams = new URLSearchParams(location.search);
var token = urlParams.get('access_token') || localStorage.getItem('user_token');
var isdev = urlParams.get('isdev') || localStorage.getItem('user_isdev') || '0';
var currentStatus = '';
var refundOrderId = null;
var reviewOrderId = null;
var reviewRating = 0;
var countdownTimer = null;

if (!token) {
    document.body.innerHTML = '<div style="text-align:center;padding:60px;color:#999"><h2>请先登录</h2></div>';
    throw new Error('No token');
}
if (token) { localStorage.setItem('user_token', token); localStorage.setItem('user_isdev', isdev); }

function api(path) { return path + (path.includes('?') ? '&' : '?') + 'access_token=' + encodeURIComponent(token) + '&isdev=' + isdev; }
function goTo(url) { var sep = url.indexOf('?') >= 0 ? '&' : '?'; location.href = url + sep + 'access_token=' + encodeURIComponent(token) + '&isdev=' + isdev; }

var statusMap = { pending:'待支付', paid:'已支付', shipped:'已发货', completed:'已完成', cancelled:'已取消', refunding:'退款中', refunded:'已退款' };
var statusClass = { pending:'s-pending', paid:'s-paid', shipped:'s-shipped', completed:'s-completed', cancelled:'s-cancelled', refunding:'s-refunding', refunded:'s-refunded' };

function parseDateTime(value) {
    if (!value) return null;
    var normalized = String(value).replace(' ', 'T');
    var date = new Date(normalized);
    if (!isNaN(date.getTime())) return date;
    return null;
}

function getCountdownInfo(expireTime) {
    var target = parseDateTime(expireTime);
    if (!target) return null;
    var diff = target.getTime() - Date.now();
    return { diff: diff, expired: diff <= 0 };
}

function formatCountdown(ms) {
    var totalSeconds = Math.max(0, Math.floor(ms / 1000));
    var hours = Math.floor(totalSeconds / 3600);
    var minutes = Math.floor((totalSeconds % 3600) / 60);
    var seconds = totalSeconds % 60;
    if (hours > 0) {
        return [hours, minutes, seconds].map(function(v){ return String(v).padStart(2, '0'); }).join(':');
    }
    return [minutes, seconds].map(function(v){ return String(v).padStart(2, '0'); }).join(':');
}

function renderCountdown(o) {
    var status = o.order_status || o.status || 'pending';
    if (status !== 'pending' || !o.expire_time) return '';
    var info = getCountdownInfo(o.expire_time);
    var css = 'countdown-bar';
    var title = '待支付订单';
    var sub = '请尽快完成支付，超时后系统将自动取消';
    var timeText = '--:--';
    if (info) {
        if (info.expired) {
            css += ' expired';
            title = '支付已超时';
            sub = '系统会自动关闭订单，如仍需购买请重新下单';
            timeText = '已超时';
        } else {
            if (info.diff <= 5 * 60 * 1000) css += ' urgent';
            sub = '支付截止 ' + String(o.expire_time).substring(0, 16).replace('T', ' ');
            timeText = '还剩 ' + formatCountdown(info.diff);
        }
    }
    return '<div class="' + css + '" data-countdown data-expire-time="' + (o.expire_time || '') + '">'
        + '<div><div class="countdown-title">' + title + '</div><div class="countdown-sub">' + sub + '</div></div>'
        + '<div class="countdown-time">' + timeText + '</div></div>';
}

function renderActions(o) {
    var status = o.order_status || o.status || 'pending';
    var html = '<div class="action-bar">';
    if (status === 'pending') {
        html += '<button class="btn btn-outline" onclick="cancelOrder(' + o.id + ')">取消订单</button>';
        if (o.expire_time && !getCountdownInfo(o.expire_time).expired) {
            html += '<button class="btn btn-primary" onclick="goTo(\'payment.html?order_id=' + o.id + '\')">立即支付</button>';
        }
    }
    if (status === 'paid' || status === 'shipped') {
        html += '<button class="btn btn-warn" onclick="openRefundModal(' + o.id + ')">申请退款</button>';
    }
    if (status === 'shipped') {
        html += '<button class="btn btn-outline" onclick="goTo(\'order_tracking.html?order_id=' + o.id + '\')">查看物流</button>';
        html += '<button class="btn btn-primary" onclick="confirmReceipt(' + o.id + ')">确认收货</button>';
    }
    if (status === 'completed') {
        if (o.has_review) {
            html += '<button class="btn btn-outline" style="color:#999;border-color:#ddd" disabled>已评价</button>';
        } else {
            html += '<button class="btn btn-primary" onclick="openReviewModal(' + o.id + ')">评价</button>';
        }
    }
    html += '</div>';
    return html === '<div class="action-bar"></div>' ? '' : html;
}

function renderLogistics(o) {
    var status = o.order_status || o.status;
    if (status !== 'shipped' && status !== 'completed') return '';
    if (!o.tracking_no && status !== 'shipped') return '';
    var trackingDesc = o.tracking_no ? '单号: ' + o.tracking_no : '点击查看物流详情';
    return '<div class="logistics-bar" onclick="goTo(\'order_tracking.html?order_id=' + o.id + '\')" style="cursor:pointer">'
        + '<div class="logistics-icon">🚚</div><div class="logistics-text">'
        + '<div class="logistics-title">' + (o.logistics_company || '快递') + ' 已发货</div>'
        + '<div class="logistics-no">' + trackingDesc + '</div>'
        + '</div><div style="color:#667eea;font-size:13px;flex-shrink:0">查看 ›</div></div>';
}

function renderProductList(items) {
    if (!items || items.length === 0) return '';
    var html = '<div class="product-list">';
    items.forEach(function(p) {
        var imgHtml = p.images ? '<img src="' + tryParseImg(p.images) + '" onerror="this.style.display=\'none\'">' : '🛍️';
        html += '<div class="product-row">'
            + '<div class="prod-img">' + imgHtml + '</div>'
            + '<div class="prod-info"><div class="prod-name">' + (p.product_name || p.item_name || '商品') + '</div>'
            + '<div class="prod-price">¥' + parseFloat(p.unit_price || p.price || 0).toFixed(2) + '</div></div>'
            + '<div class="prod-qty">×' + (p.quantity || 1) + '</div>'
            + '</div>';
    });
    html += '</div>';
    return html;
}

function tryParseImg(images) {
    try {
        var arr = JSON.parse(images);
        return arr && arr[0] ? arr[0] : '';
    } catch(e) { return images || ''; }
}

function refreshCountdowns() {
    document.querySelectorAll('[data-countdown]').forEach(function(el) {
        var expireTime = el.getAttribute('data-expire-time');
        var info = getCountdownInfo(expireTime);
        var titleEl = el.querySelector('.countdown-title');
        var subEl = el.querySelector('.countdown-sub');
        var timeEl = el.querySelector('.countdown-time');
        if (!info || !titleEl || !subEl || !timeEl) return;
        el.classList.remove('urgent', 'expired');
        if (info.expired) {
            el.classList.add('expired');
            titleEl.textContent = '支付已超时';
            subEl.textContent = '系统会自动关闭订单，如仍需购买请重新下单';
            timeEl.textContent = '已超时';
            return;
        }
        if (info.diff <= 5 * 60 * 1000) el.classList.add('urgent');
        titleEl.textContent = '待支付订单';
        subEl.textContent = '支付截止 ' + String(expireTime).substring(0, 16).replace('T', ' ');
        timeEl.textContent = '还剩 ' + formatCountdown(info.diff);
    });
}

function startCountdownTimer() {
    if (countdownTimer) clearInterval(countdownTimer);
    refreshCountdowns();
    countdownTimer = setInterval(refreshCountdowns, 1000);
}

async function loadList() {
    var url = api('/api/user/orders?page=1&page_size=20' + (currentStatus ? '&status=' + currentStatus : ''));
    document.getElementById('list').innerHTML = '<div class="empty"><div class="empty-icon">⏳</div><p>加载中...</p></div>';
    try {
        var res = await fetch(url);
        var data = await res.json();
        if (!data.success || !data.data || !data.data.items || data.data.items.length === 0) {
            document.getElementById('list').innerHTML = '<div class="empty"><div class="empty-icon">📦</div><p>暂无订单记录</p></div>';
            return;
        }
        var orders = data.data.items;
        var detailPromises = orders.map(function(o) {
            return fetch(api('/api/user/orders/' + o.id))
                .then(function(r){ return r.json(); })
                .then(function(d){ return d.success ? Object.assign({}, o, d.data || {}) : o; })
                .catch(function(){ return o; });
        });
        var details = await Promise.all(detailPromises);

        var html = '';
        details.forEach(function(o) {
            var status = o.order_status || o.status || 'pending';
            var amount = parseFloat(o.actual_amount || o.total_amount || 0).toFixed(2);
            var products = o.order_items || o.items || [];
            html += '<div class="item">'
                + '<div class="item-head">'
                + '<span class="item-no">订单号: ' + (o.order_no || '') + '</span>'
                + '<span class="item-status ' + (statusClass[status] || 's-pending') + '">' + (statusMap[status] || status) + '</span>'
                + '</div>'
                + renderCountdown(o)
                + renderProductList(products)
                + renderLogistics(o)
                + (o.shipping_address ? '<div style="padding:6px 15px;font-size:12px;color:#999">📍 ' + o.shipping_address + '</div>' : '')
                + '<div class="amount-bar"><span class="amount-label">实付</span><span class="amount-value">¥' + amount + '</span></div>'
                + renderActions(o)
                + '</div>';
        });
        document.getElementById('list').innerHTML = html;
        startCountdownTimer();
    } catch(e) {
        document.getElementById('list').innerHTML = '<div class="empty"><div class="empty-icon">😞</div><p>加载失败，请重试</p></div>';
    }
}

async function cancelOrder(id) {
    if (!confirm('确认取消该订单？')) return;
    try {
        var r = await fetch(api('/api/user/orders/' + id + '/cancel'), { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
        var d = await r.json();
        if (d.success) { alert('订单已取消'); loadList(); }
        else alert(d.msg || '取消失败');
    } catch(e) { alert('操作失败'); }
}

async function confirmReceipt(id) {
    if (!confirm('确认已收到货物？')) return;
    try {
        var r = await fetch(api('/api/user/orders/' + id + '/confirm'), { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
        var d = await r.json();
        if (d.success) { alert('确认收货成功！感谢您的购买'); loadList(); }
        else alert(d.msg || '操作失败');
    } catch(e) { alert('操作失败'); }
}

function openRefundModal(id) {
    refundOrderId = id;
    document.getElementById('refundReason').value = '';
    document.getElementById('refundModal').classList.add('show');
}

function closeRefundModal(e) {
    if (e && e.target !== document.getElementById('refundModal')) return;
    document.getElementById('refundModal').classList.remove('show');
    refundOrderId = null;
}

async function submitRefund() {
    var reason = document.getElementById('refundReason').value.trim();
    if (!reason) { alert('请填写退款原因'); return; }
    if (!refundOrderId) return;
    try {
        var r = await fetch(api('/api/user/orders/' + refundOrderId + '/refund'), {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({reason: reason})
        });
        var d = await r.json();
        if (d.success) {
            alert('退款申请已提交，请等待审核');
            document.getElementById('refundModal').classList.remove('show');
            loadList();
        } else { alert(d.msg || '申请失败'); }
    } catch(e) { alert('操作失败'); }
}

function openReviewModal(id) {
    reviewOrderId = id;
    reviewRating = 0;
    document.getElementById('reviewContent').value = '';
    document.getElementById('reviewAnonymous').checked = false;
    document.querySelectorAll('#ratingStars .star').forEach(function(s) { s.classList.remove('active'); });
    document.getElementById('reviewModal').classList.add('show');
    document.querySelectorAll('#ratingStars .star').forEach(function(star) {
        star.onclick = function() {
            reviewRating = parseInt(star.dataset.rating, 10);
            document.querySelectorAll('#ratingStars .star').forEach(function(s, i) {
                s.classList.toggle('active', i < reviewRating);
            });
        };
    });
}

function closeReviewModal(e) {
    if (e && e.target !== document.getElementById('reviewModal')) return;
    document.getElementById('reviewModal').classList.remove('show');
    reviewOrderId = null;
    reviewRating = 0;
}

async function submitReview() {
    if (!reviewRating) { alert('请选择评分'); return; }
    if (!reviewOrderId) return;
    var content = document.getElementById('reviewContent').value.trim();
    var isAnonymous = document.getElementById('reviewAnonymous').checked ? 1 : 0;
    try {
        var r = await fetch(api('/api/user/reviews'), {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                target_type: 'order',
                target_id: reviewOrderId,
                target_name: '订单' + reviewOrderId,
                rating: reviewRating,
                content: content,
                images: [],
                is_anonymous: isAnonymous
            })
        });
        var d = await r.json();
        if (d.success) {
            alert('评价成功，感谢您的反馈！');
            document.getElementById('reviewModal').classList.remove('show');
            loadList();
        } else { alert(d.msg || '评价失败'); }
    } catch(e) { alert('操作失败'); }
}

document.querySelectorAll('.filter-item').forEach(function(el) {
    el.addEventListener('click', function() {
        document.querySelectorAll('.filter-item').forEach(function(e) { e.classList.remove('active'); });
        el.classList.add('active');
        currentStatus = el.dataset.status;
        loadList();
    });
});

loadList();
</script>
</body>
</html>
