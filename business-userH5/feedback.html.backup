<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>意见反馈 - 社区服务</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; min-height: 100vh; }
        
        .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 15px 20px; display: flex; align-items: center; gap: 12px; }
        .back-btn { font-size: 20px; cursor: pointer; text-decoration: none; color: white; }
        .header h1 { font-size: 17px; flex: 1; }
        
        /* 反馈表单 */
        .form-section { background: white; margin: 15px; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .form-title { font-size: 16px; font-weight: 600; color: #333; margin-bottom: 15px; display: flex; align-items: center; gap: 8px; }
        .form-group { margin-bottom: 15px; }
        .form-label { font-size: 14px; color: #666; margin-bottom: 8px; display: block; }
        .form-label .required { color: #ff4d4f; margin-left: 2px; }
        
        .type-selector { display: flex; gap: 10px; flex-wrap: wrap; }
        .type-btn { padding: 8px 16px; border-radius: 20px; border: 1.5px solid #e8e8e8; background: white; font-size: 13px; color: #666; cursor: pointer; transition: all 0.2s; }
        .type-btn.active { border-color: #667eea; background: #f0f0ff; color: #667eea; font-weight: 500; }
        .type-btn .icon { margin-right: 4px; }
        
        input[type="text"], input[type="tel"], textarea { width: 100%; padding: 12px; border: 1.5px solid #e8e8e8; border-radius: 8px; font-size: 14px; color: #333; outline: none; transition: border-color 0.2s; }
        input[type="text"]:focus, input[type="tel"]:focus, textarea:focus { border-color: #667eea; }
        textarea { height: 120px; resize: none; }
        .char-count { text-align: right; font-size: 12px; color: #bbb; margin-top: 4px; }
        .char-count.over { color: #ff4d4f; }
        
        .submit-btn { width: 100%; padding: 14px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 500; cursor: pointer; transition: opacity 0.2s; }
        .submit-btn:active { opacity: 0.85; }
        .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        
        /* 我的反馈列表 */
        .section-divider { padding: 20px 15px 10px; font-size: 15px; font-weight: 600; color: #333; display: flex; align-items: center; gap: 8px; }
        .section-divider .count { font-size: 12px; color: #999; font-weight: 400; }
        
        .feedback-list { padding: 0 15px 15px; }
        .feedback-item { background: white; border-radius: 12px; padding: 15px; margin-bottom: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
        .feedback-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
        .feedback-title { font-size: 15px; font-weight: 500; color: #333; flex: 1; margin-right: 10px; }
        .feedback-type-tag { font-size: 11px; padding: 2px 8px; border-radius: 10px; white-space: nowrap; }
        .tag-suggestion { background: #e6f7ff; color: #1890ff; }
        .tag-bug { background: #fff2f0; color: #ff4d4f; }
        .tag-complaint { background: #fff7e6; color: #fa8c16; }
        .tag-praise { background: #f6ffed; color: #52c41a; }
        
        .feedback-content { font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 8px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; }
        
        .feedback-reply { background: #f6ffed; border-radius: 8px; padding: 10px 12px; margin-bottom: 8px; border-left: 3px solid #52c41a; }
        .reply-label { font-size: 12px; color: #52c41a; font-weight: 500; margin-bottom: 4px; }
        .reply-content { font-size: 13px; color: #333; line-height: 1.5; }
        
        .feedback-footer { display: flex; justify-content: space-between; align-items: center; }
        .feedback-time { font-size: 12px; color: #bbb; }
        .feedback-status { font-size: 12px; padding: 2px 8px; border-radius: 4px; }
        .status-pending { background: #fff7e6; color: #fa8c16; }
        .status-replied { background: #f6ffed; color: #52c41a; }
        .status-closed { background: #f0f0f0; color: #999; }
        
        .empty { text-align: center; padding: 40px 20px; color: #bbb; }
        .empty-icon { font-size: 48px; margin-bottom: 10px; }
        .loading { text-align: center; padding: 30px; color: #999; }
        
        /* 提交成功弹窗 */
        .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 999; }
        .modal-overlay.show { display: flex; }
        .modal-box { background: white; border-radius: 16px; padding: 30px; width: 280px; text-align: center; }
        .modal-icon { font-size: 56px; margin-bottom: 15px; }
        .modal-title { font-size: 18px; font-weight: 600; color: #333; margin-bottom: 8px; }
        .modal-desc { font-size: 14px; color: #666; margin-bottom: 20px; }
        .modal-btn { padding: 10px 40px; background: #667eea; color: white; border: none; border-radius: 20px; font-size: 14px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="header">
        <a class="back-btn" onclick="history.back()">←</a>
        <h1>意见反馈</h1>
    </div>
    
    <!-- 反馈表单 -->
    <div class="form-section">
        <div class="form-title">📝 提交反馈</div>
        <div class="form-group">
            <div class="form-label">反馈类型<span class="required">*</span></div>
            <div class="type-selector">
                <div class="type-btn active" data-type="suggestion" onclick="selectType(this)">💡 建议</div>
                <div class="type-btn" data-type="bug" onclick="selectType(this)">🐛 问题</div>
                <div class="type-btn" data-type="complaint" onclick="selectType(this)">😤 投诉</div>
                <div class="type-btn" data-type="praise" onclick="selectType(this)">👍 表扬</div>
            </div>
        </div>
        <div class="form-group">
            <div class="form-label">标题<span class="required">*</span></div>
            <input type="text" id="fbTitle" placeholder="请简要描述您的反馈" maxlength="100">
            <div class="char-count"><span id="titleCount">0</span>/100</div>
        </div>
        <div class="form-group">
            <div class="form-label">详细内容<span class="required">*</span></div>
            <textarea id="fbContent" placeholder="请详细描述您遇到的问题或建议..." maxlength="2000"></textarea>
            <div class="char-count"><span id="contentCount">0</span>/2000</div>
        </div>
        <div class="form-group">
            <div class="form-label">联系方式（选填）</div>
            <input type="tel" id="fbContact" placeholder="方便我们回复您">
        </div>
        <button class="submit-btn" id="submitBtn" onclick="submitFeedback()">提交反馈</button>
    </div>
    
    <!-- 我的反馈列表 -->
    <div class="section-divider">📋 我的反馈 <span class="count" id="totalCount"></span></div>
    <div class="feedback-list" id="feedbackList">
        <div class="loading">加载中...</div>
    </div>
    
    <!-- 成功弹窗 -->
    <div class="modal-overlay" id="successModal">
        <div class="modal-box">
            <div class="modal-icon">✅</div>
            <div class="modal-title">提交成功</div>
            <div class="modal-desc">感谢您的反馈，我们会尽快处理！</div>
            <button class="modal-btn" onclick="closeModal()">我知道了</button>
        </div>
    </div>

    <script>
    const API = localStorage.getItem('apiBase') || '';
    let currentType = 'suggestion';
    
    function escapeHtml(text) {
        if (text === null || text === undefined) return '';
        return String(text).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
    
    function getToken() {
        return localStorage.getItem('access_token') || new URLSearchParams(location.search).get('access_token') || '';
    }
    
    function selectType(el) {
        document.querySelectorAll('.type-btn').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        currentType = el.dataset.type;
    }
    
    // 字数统计
    document.getElementById('fbTitle').addEventListener('input', function() {
        const count = this.value.length;
        document.getElementById('titleCount').textContent = count;
        document.getElementById('titleCount').parentElement.className = 'char-count' + (count >= 100 ? ' over' : '');
    });
    document.getElementById('fbContent').addEventListener('input', function() {
        const count = this.value.length;
        document.getElementById('contentCount').textContent = count;
        document.getElementById('contentCount').parentElement.className = 'char-count' + (count >= 2000 ? ' over' : '');
    });
    
    async function submitFeedback() {
        const title = document.getElementById('fbTitle').value.trim();
        const content = document.getElementById('fbContent').value.trim();
        const contact = document.getElementById('fbContact').value.trim();
        
        if (!title) { alert('请输入标题'); return; }
        if (!content) { alert('请输入详细内容'); return; }
        
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.textContent = '提交中...';
        
        try {
            const res = await fetch(`${API}/api/user/feedback`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Token': getToken() },
                body: JSON.stringify({
                    feedback_type: currentType,
                    title: title,
                    content: content,
                    contact: contact
                })
            });
            const json = await res.json();
            if (json.success) {
                document.getElementById('successModal').classList.add('show');
                document.getElementById('fbTitle').value = '';
                document.getElementById('fbContent').value = '';
                document.getElementById('fbContact').value = '';
                document.getElementById('titleCount').textContent = '0';
                document.getElementById('contentCount').textContent = '0';
                loadFeedback();
            } else {
                alert(json.msg || '提交失败');
            }
        } catch (e) {
            alert('网络错误，请重试');
        } finally {
            btn.disabled = false;
            btn.textContent = '提交反馈';
        }
    }
    
    function closeModal() {
        document.getElementById('successModal').classList.remove('show');
    }
    
    async function loadFeedback() {
        const list = document.getElementById('feedbackList');
        list.innerHTML = '<div class="loading">加载中...</div>';
        
        try {
            const res = await fetch(`${API}/api/user/feedback?page=1&page_size=20`, {
                headers: { 'Token': getToken() }
            });
            const json = await res.json();
            if (json.success) {
                const items = json.data.items || [];
                document.getElementById('totalCount').textContent = `共${json.data.total}条`;
                
                if (items.length === 0) {
                    list.innerHTML = '<div class="empty"><div class="empty-icon">📭</div><p>暂无反馈记录</p></div>';
                    return;
                }
                
                const typeLabels = { suggestion: '建议', bug: '问题', complaint: '投诉', praise: '表扬' };
                const typeIcons = { suggestion: '💡', bug: '🐛', complaint: '😤', praise: '👍' };
                const statusLabels = { pending: '待处理', replied: '已回复', closed: '已关闭' };
                
                list.innerHTML = items.map(fb => `
                    <div class="feedback-item">
                        <div class="feedback-header">
                            <div class="feedback-title">${escapeHtml(fb.title || '')}</div>
                            <span class="feedback-type-tag tag-${fb.feedback_type}">${typeLabels[fb.feedback_type] || '建议'}</span>
                        </div>
                        <div class="feedback-content">${escapeHtml(fb.content || '')}</div>
                        ${fb.reply ? `
                        <div class="feedback-reply">
                            <div class="reply-label">💬 官方回复</div>
                            <div class="reply-content">${escapeHtml(fb.reply)}</div>
                        </div>` : ''}
                        <div class="feedback-footer">
                            <span class="feedback-time">${formatTime(fb.created_at)}</span>
                            <span class="feedback-status status-${fb.status}">${statusLabels[fb.status] || '待处理'}</span>
                        </div>
                    </div>
                `).join('');
            }
        } catch (e) {
            list.innerHTML = '<div class="empty"><p>加载失败</p></div>';
        }
    }
    
    function formatTime(t) {
        if (!t) return '';
        const d = new Date(t);
        const now = new Date();
        const diff = now - d;
        if (diff < 60000) return '刚刚';
        if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前';
        if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前';
        if (diff < 172800000) return '昨天';
        return `${d.getMonth()+1}/${d.getDate()} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
    }
    
    loadFeedback();
    </script>
</body>
</html>
