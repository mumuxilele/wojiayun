<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>收货地址 - 社区商业</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; background: #f5f5f5; min-height: 100vh; }
        .header { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 15px; display: flex; align-items: center; position: sticky; top: 0; z-index: 100; }
        .header h1 { font-size: 17px; flex: 1; }
        .back { color: white; text-decoration: none; font-size: 14px; }
        .btn-add { position: fixed; bottom: 20px; right: 20px; width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; font-size: 26px; cursor: pointer; box-shadow: 0 4px 12px rgba(102,126,234,0.4); z-index: 99; }
        .addr-list { padding: 10px 15px 80px; }
        .addr-item { background: white; border-radius: 12px; padding: 14px; margin-bottom: 10px; position: relative; }
        .addr-name { font-size: 15px; font-weight: 600; color: #333; }
        .addr-phone { font-size: 13px; color: #666; margin-left: 10px; }
        .addr-detail { font-size: 13px; color: #999; margin-top: 6px; line-height: 1.5; }
        .addr-tag { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 4px; background: #fff0f6; color: #eb2f96; margin-top: 6px; }
        .addr-actions { position: absolute; top: 14px; right: 14px; display: flex; gap: 12px; }
        .addr-actions a { font-size: 12px; color: #667eea; text-decoration: none; cursor: pointer; }
        .addr-actions .del { color: #f5222d; }
        .empty { text-align: center; padding: 60px 20px; color: #bbb; }
        .empty-icon { font-size: 48px; margin-bottom: 10px; }

        /* 弹窗 */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 200; justify-content: center; align-items: center; }
        .modal-overlay.active { display: flex; }
        .modal { background: white; border-radius: 16px; width: 90%; max-width: 400px; max-height: 80vh; overflow-y: auto; padding: 20px; }
        .modal h3 { font-size: 16px; margin-bottom: 15px; }
        .form-group { margin-bottom: 12px; }
        .form-group label { display: block; font-size: 13px; color: #666; margin-bottom: 4px; }
        .form-group input, .form-group select { width: 100%; padding: 10px 12px; border: 1px solid #e0e0e0; border-radius: 8px; font-size: 14px; outline: none; }
        .form-group input:focus { border-color: #667eea; }
        .form-row { display: flex; gap: 10px; }
        .form-row .form-group { flex: 1; }
        .btn-primary { width: 100%; padding: 12px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 8px; font-size: 15px; cursor: pointer; margin-top: 10px; }
        .btn-cancel { width: 100%; padding: 12px; background: #f5f5f5; color: #666; border: none; border-radius: 8px; font-size: 15px; cursor: pointer; margin-top: 8px; }
    </style>
</head>
<body>
    <div class="header">
        <a href="member.html" class="back">← 返回</a>
        <h1>📍 收货地址</h1>
    </div>
    <div class="addr-list" id="addrList"></div>
    <button class="btn-add" onclick="showModal()">+</button>

    <div class="modal-overlay" id="modal">
        <div class="modal">
            <h3 id="modalTitle">新增地址</h3>
            <input type="hidden" id="editId">
            <div class="form-group">
                <label>联系人</label>
                <input type="text" id="contactName" placeholder="请输入联系人姓名" maxlength="20">
            </div>
            <div class="form-group">
                <label>联系电话</label>
                <input type="tel" id="contactPhone" placeholder="请输入手机号" maxlength="11">
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>省</label>
                    <input type="text" id="province" placeholder="省份" maxlength="20">
                </div>
                <div class="form-group">
                    <label>市</label>
                    <input type="text" id="city" placeholder="城市" maxlength="20">
                </div>
            </div>
            <div class="form-group">
                <label>区</label>
                <input type="text" id="district" placeholder="区/县" maxlength="20">
            </div>
            <div class="form-group">
                <label>详细地址</label>
                <input type="text" id="address" placeholder="街道/楼栋/门牌号" maxlength="200">
            </div>
            <button class="btn-primary" onclick="saveAddress()">保存</button>
            <button class="btn-cancel" onclick="hideModal()">取消</button>
        </div>
    </div>

<script>
var TOKEN = new URLSearchParams(location.search).get('access_token') || localStorage.getItem('access_token') || '';
var ISDEV = new URLSearchParams(location.search).get('isdev') || '0';

function apiUrl(path) {
    return path + '?access_token=' + encodeURIComponent(TOKEN) + '&isdev=' + ISDEV;
}

function escapeHtml(text) {
    if (!text) return '';
    return String(text).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

function loadAddresses() {
    fetch(apiUrl('/api/user/addresses')).then(r => r.json()).then(d => {
        var list = document.getElementById('addrList');
        if (!d.success || !d.data || d.data.length === 0) {
            list.innerHTML = '<div class="empty"><div class="empty-icon">📭</div><div>暂无收货地址</div><div style="margin-top:8px;font-size:12px">点击右下角 + 添加</div></div>';
            return;
        }
        list.innerHTML = d.data.map(a => `
            <div class="addr-item">
                <div style="display:flex;align-items:center;">
                    <span class="addr-name">${escapeHtml(a.contact_name)}</span>
                    <span class="addr-phone">${escapeHtml(a.contact_phone)}</span>
                    ${a.is_default ? '<span class="addr-tag">默认</span>' : ''}
                </div>
                <div class="addr-detail">${escapeHtml(a.province)}${escapeHtml(a.city)}${escapeHtml(a.district)}${escapeHtml(a.address)}</div>
                <div class="addr-actions">
                    <a onclick="editAddress(${a.id})">编辑</a>
                    <a class="del" onclick="deleteAddress(${a.id})">删除</a>
                    ${!a.is_default ? '<a onclick="setDefault(' + a.id + ')">默认</a>' : ''}
                </div>
            </div>
        `).join('');
    }).catch(() => {
        document.getElementById('addrList').innerHTML = '<div class="empty">加载失败</div>';
    });
}

function showModal(id) {
    document.getElementById('modal').classList.add('active');
    if (id) {
        document.getElementById('modalTitle').textContent = '编辑地址';
        document.getElementById('editId').value = id;
        // 加载地址信息
        fetch(apiUrl('/api/user/addresses/' + id)).then(r => r.json()).then(d => {
            if (d.success && d.data) {
                document.getElementById('contactName').value = d.data.contact_name || '';
                document.getElementById('contactPhone').value = d.data.contact_phone || '';
                document.getElementById('province').value = d.data.province || '';
                document.getElementById('city').value = d.data.city || '';
                document.getElementById('district').value = d.data.district || '';
                document.getElementById('address').value = d.data.address || '';
            }
        });
    } else {
        document.getElementById('modalTitle').textContent = '新增地址';
        document.getElementById('editId').value = '';
        document.getElementById('contactName').value = '';
        document.getElementById('contactPhone').value = '';
        document.getElementById('province').value = '';
        document.getElementById('city').value = '';
        document.getElementById('district').value = '';
        document.getElementById('address').value = '';
    }
}

function hideModal() {
    document.getElementById('modal').classList.remove('active');
}

function editAddress(id) { showModal(id); }

function saveAddress() {
    var name = document.getElementById('contactName').value.trim();
    var phone = document.getElementById('contactPhone').value.trim();
    if (!name) { alert('请输入联系人'); return; }
    if (!phone || phone.length < 11) { alert('请输入正确的手机号'); return; }
    var body = {
        contact_name: name,
        contact_phone: phone,
        province: document.getElementById('province').value.trim(),
        city: document.getElementById('city').value.trim(),
        district: document.getElementById('district').value.trim(),
        address: document.getElementById('address').value.trim()
    };
    var editId = document.getElementById('editId').value;
    var url = editId ? apiUrl('/api/user/addresses/' + editId) : apiUrl('/api/user/addresses');
    var method = editId ? 'PUT' : 'POST';
    fetch(url, { method, headers: {'Content-Type': 'application/json'}, body: JSON.stringify(body) })
        .then(r => r.json()).then(d => {
            if (d.success) { hideModal(); loadAddresses(); }
            else { alert(d.msg || '保存失败'); }
        }).catch(() => alert('网络错误'));
}

function deleteAddress(id) {
    if (!confirm('确认删除该地址？')) return;
    fetch(apiUrl('/api/user/addresses/' + id), { method: 'DELETE' })
        .then(r => r.json()).then(d => {
            if (d.success) loadAddresses();
            else alert(d.msg || '删除失败');
        });
}

function setDefault(id) {
    fetch(apiUrl('/api/user/addresses/' + id + '/default'), { method: 'POST' })
        .then(r => r.json()).then(d => {
            if (d.success) loadAddresses();
            else alert(d.msg || '设置失败');
        });
}

loadAddresses();
</script>
</body>
</html>
