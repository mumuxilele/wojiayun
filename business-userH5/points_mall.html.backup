<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>积分商城</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;background:#f5f5f5;min-height:100vh;padding-bottom:80px;color:#333}
.header{background:linear-gradient(135deg,#ff6b6b,#ee5a5a);color:white;padding:15px;display:flex;align-items:center;position:sticky;top:0;z-index:50}
.header h1{font-size:18px;flex:1;text-align:center}
.back{color:white;font-size:20px;text-decoration:none;padding:4px 8px}

/* 用户积分信息卡 */
.points-banner{background:linear-gradient(135deg,#ff6b6b,#ee5a5a);padding:20px 16px 30px;color:white}
.points-card{background:rgba(255,255,255,.2);border-radius:16px;padding:16px;display:flex;align-items:center;gap:16px}
.points-icon{font-size:40px;flex-shrink:0}
.points-info{flex:1}
.points-balance{font-size:32px;font-weight:700;line-height:1.2}
.points-label{font-size:13px;opacity:.85;margin-top:4px}
.points-btn{background:rgba(255,255,255,.25);border:none;border-radius:20px;padding:8px 16px;color:white;font-size:13px;font-weight:600;cursor:pointer;flex-shrink:0}
.points-card-shadow{height:20px;background:#f5f5f5;border-radius:16px 16px 0 0;margin:-10px 16px 0}

/* 导航tabs */
.tabs{display:flex;background:white;padding:0 8px;gap:4px;border-bottom:1px solid #f0f0f0}
.tab{flex:1;padding:12px 8px;text-align:center;font-size:14px;color:#666;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s}
.tab.active{color:#ff5252;border-bottom-color:#ff5252;font-weight:600}
.tab:active{background:#f9f9f9}

/* 搜索栏 */
.search-bar{background:white;padding:12px 16px;display:flex;gap:10px;align-items:center}
.search-input{flex:1;background:#f5f5f5;border:none;border-radius:20px;padding:8px 16px;font-size:14px;outline:none}
.search-input:focus{background:#eee}

/* 商品网格 */
.goods-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:10px}
.goods-card{background:white;border-radius:12px;overflow:hidden;cursor:pointer;transition:transform .15s}
.goods-card:active{transform:scale(.98)}
.goods-img{width:100%;aspect-ratio:1;background:#f5f5f5;display:flex;align-items:center;justify-content:center;font-size:48px}
.goods-img img{width:100%;height:100%;object-fit:cover}
.goods-info{padding:10px}
.goods-name{font-size:14px;color:#333;font-weight:500;line-height:1.4;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.goods-bottom{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.points-tag{background:linear-gradient(135deg,#ff5252,#ff6b6b);color:white;font-size:11px;padding:2px 6px;border-radius:4px;font-weight:600}
.points-value{font-size:16px;color:#ff5252;font-weight:700}
.points-value::before{content:'';display:inline}
.original-price{font-size:12px;color:#bbb;text-decoration:line-through;margin-left:auto}
.stock-bar{height:3px;background:#f0f0f0;border-radius:2px;margin-top:8px;overflow:hidden}
.stock-fill{height:100%;background:linear-gradient(90deg,#ff5252,#ff6b6b);border-radius:2px;transition:width .3s}
.stock-text{font-size:11px;color:#999;margin-top:4px}
.exchange-btn{display:block;width:100%;margin-top:8px;padding:7px 0;background:linear-gradient(135deg,#ff5252,#ff6b6b);color:white;border:none;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer}
.exchange-btn:active{opacity:.88;transform:scale(.98)}

/* 空状态 */
.empty{text-align:center;padding:60px 20px;color:#bbb}
.empty-icon{font-size:60px;margin-bottom:12px}
.empty-text{font-size:14px;margin-bottom:16px}
.go-btn{display:inline-block;padding:10px 24px;background:linear-gradient(135deg,#ff5252,#ff6b6b);color:white;border-radius:20px;font-size:14px;font-weight:600;text-decoration:none}

/* 加载 */
.loading{text-align:center;padding:60px;color:#bbb}

/* 兑换弹窗 */
.mask{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:100;display:none}
.mask.show{display:block}
.exchange-sheet{position:fixed;bottom:0;left:0;right:0;background:white;border-radius:16px 16px 0 0;z-index:101;transform:translateY(100%);transition:transform .3s;max-height:85vh;overflow-y:auto}
.exchange-sheet.show{transform:translateY(0)}
.sheet-header{padding:16px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #f0f0f0;position:sticky;top:0;background:white;z-index:1}
.sheet-header h3{font-size:16px;font-weight:600}
.sheet-close{font-size:22px;color:#999;cursor:pointer;padding:0 4px}
.sheet-content{padding:16px}
.exchange-goods{display:flex;gap:12px;padding-bottom:16px;border-bottom:1px solid #f5f5f5;margin-bottom:16px}
.exchange-img{width:80px;height:80px;border-radius:8px;background:#f5f5f5;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:32px}
.exchange-img img{width:100%;height:100%;object-fit:cover}
.exchange-info{flex:1}
.exchange-name{font-size:15px;font-weight:600;color:#333;margin-bottom:8px;line-height:1.4}
.exchange-points{font-size:20px;color:#ff5252;font-weight:700}
.exchange-points-label{font-size:12px;color:#999}
.exchange-stock{font-size:12px;color:#999;margin-top:4px}
.exchange-form{margin-top:16px}
.form-row{margin-bottom:14px}
.form-label{font-size:13px;color:#666;margin-bottom:6px;font-weight:500}
.form-input{width:100%;border:1px solid #e0e0e0;border-radius:8px;padding:10px 12px;font-size:14px;outline:none;transition:border-color .2s}
.form-input:focus{border-color:#ff5252}
.form-textarea{resize:none;height:80px}
.form-tip{font-size:12px;color:#999;margin-top:4px;line-height:1.5}
.confirm-exchange{width:100%;padding:14px;background:linear-gradient(135deg,#ff5252,#ff6b6b);color:white;border:none;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;margin-top:8px}
.confirm-exchange:active{opacity:.88;transform:scale(.98)}
.confirm-exchange:disabled{background:#ccc;cursor:not-allowed}

/* Toast */
.toast{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.9);background:rgba(0,0,0,.75);color:white;padding:12px 24px;border-radius:10px;font-size:14px;z-index:999;opacity:0;transition:all .2s;pointer-events:none;white-space:nowrap}
.toast.show{opacity:1;transform:translate(-50%,-50%) scale(1)}
</style>
</head>
<body>

<div class="header">
  <a href="javascript:history.back()" class="back">&#8592;</a>
  <h1>积分商城</h1>
  <div style="width:40px"></div>
</div>

<!-- 积分信息卡 -->
<div class="points-banner">
  <div class="points-card">
    <div class="points-icon">&#11088;</div>
    <div class="points-info">
      <div class="points-balance" id="myPoints">--</div>
      <div class="points-label">我的积分</div>
    </div>
    <button class="points-btn" onclick="location.href='member.html'">积分明细</button>
  </div>
</div>
<div class="points-card-shadow"></div>

<!-- 搜索 -->
<div class="search-bar">
  <input type="text" class="search-input" id="searchInput" placeholder="搜索积分商品..." onkeyup="if(event.key==='Enter')loadGoods()">
</div>

<!-- 商品列表 -->
<div id="goodsList"><div class="loading">加载中...</div></div>

<!-- 兑换弹窗 -->
<div class="mask" id="mask" onclick="closeSheet()"></div>
<div class="exchange-sheet" id="exchangeSheet">
  <div class="sheet-header">
    <h3>积分兑换</h3>
    <span class="sheet-close" onclick="closeSheet()">&#10005;</span>
  </div>
  <div class="sheet-content">
    <div class="exchange-goods">
      <div class="exchange-img" id="sheetImg">&#127873;</div>
      <div class="exchange-info">
        <div class="exchange-name" id="sheetName"></div>
        <div class="exchange-points"><span id="sheetPoints"></span> <span class="exchange-points-label">积分</span></div>
        <div class="exchange-stock" id="sheetStock"></div>
      </div>
    </div>
    <div class="exchange-form">
      <div class="form-row">
        <div class="form-label">收货人姓名</div>
        <input type="text" class="form-input" id="inputName" placeholder="请输入收货人姓名">
      </div>
      <div class="form-row">
        <div class="form-label">联系电话</div>
        <input type="tel" class="form-input" id="inputPhone" placeholder="请输入手机号码" maxlength="11">
      </div>
      <div class="form-row">
        <div class="form-label">收货地址</div>
        <textarea class="form-input form-textarea" id="inputAddress" placeholder="请输入详细收货地址（省市区+详细地址）"></textarea>
      </div>
      <div class="form-tip" id="formTip"></div>
      <button class="confirm-exchange" id="confirmBtn" onclick="doExchange()">确认兑换</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const API_BASE = '/api/user';
let token = localStorage.getItem('access_token') || '';
let ecId = localStorage.getItem('ec_id') || '1';
let projectId = localStorage.getItem('project_id') || '1';
let currentGoods = null;
let page = 1;
let loading = false;

// ============ 初始化 ============
document.addEventListener('DOMContentLoaded', function() {
  loadMyPoints();
  loadGoods();
});

function getHeaders() {
  return {
    'Authorization': 'Bearer ' + token,
    'Content-Type': 'application/json'
  };
}

// ============ 我的积分 ============
async function loadMyPoints() {
  try {
    const resp = await fetch(`${API_BASE}/member?access_token=${token}&ec_id=${ecId}&project_id=${projectId}`);
    const json = await resp.json();
    if (json.success && json.data) {
      document.getElementById('myPoints').textContent = (json.data.points || 0).toLocaleString();
    }
  } catch(e) {
    document.getElementById('myPoints').textContent = '--';
  }
}

// ============ 商品列表 ============
async function loadGoods() {
  if (loading) return;
  loading = true;
  const listEl = document.getElementById('goodsList');
  if (page === 1) listEl.innerHTML = '<div class="loading">加载中...</div>';

  try {
    const keyword = encodeURIComponent(document.getElementById('searchInput').value.trim());
    let url = `${API_BASE}/points-mall?access_token=${token}&ec_id=${ecId}&project_id=${projectId}&page=${page}&page_size=20`;
    if (keyword) url += '&keyword=' + keyword;

    const resp = await fetch(url);
    const json = await resp.json();
    if (!json.success) throw new Error(json.msg);

    const data = json.data || {};
    const items = data.items || [];
    if (page === 1 && items.length === 0) {
      listEl.innerHTML = '<div class="empty"><div class="empty-icon">&#127873;</div><div class="empty-text">暂无积分商品<br>去看看其他活动吧~</div></div>';
      loading = false;
      return;
    }

    if (page === 1) {
      listEl.innerHTML = '';
    }

    items.forEach(g => renderGoodsCard(g));
    page++;
    if (items.length < 20) {
      listEl.innerHTML += '<div style="text-align:center;padding:16px;color:#bbb;font-size:13px">— 没有更多了 —</div>';
    }
  } catch(e) {
    document.getElementById('goodsList').innerHTML = '<div class="empty"><div class="empty-icon">&#9888;</div><div class="empty-text">加载失败<br><span style="font-size:12px">' + e.message + '</span></div></div>';
  }
  loading = false;
}

function renderGoodsCard(g) {
  const listEl = document.getElementById('goodsList');
  const stockPercent = g.stock > 0 && g.total_stock > 0 ? Math.min(100, Math.round((g.stock / g.total_stock) * 100)) : 100;
  const soldCount = (g.sold_count || 0);

  let imgHtml = '';
  if (g.goods_image) {
    imgHtml = `<img src="${g.goods_image}" onerror="this.parentElement.innerHTML='&#127873;'">`;
  }

  const card = document.createElement('div');
  card.className = 'goods-card';
  card.innerHTML = `
    <div class="goods-img">${imgHtml || '&#127873;'}</div>
    <div class="goods-info">
      <div class="goods-name">${g.goods_name || ''}</div>
      <div class="goods-bottom">
        <span class="points-tag">积分</span>
        <span class="points-value">${(g.points_price || 0).toLocaleString()}</span>
        <span class="original-price">¥${(g.original_price || 0).toFixed(2)}</span>
      </div>
      <div class="stock-bar"><div class="stock-fill" style="width:${stockPercent}%"></div></div>
      <div class="stock-text">剩余 ${g.stock || 0} 件 | 已兑 ${soldCount} 件</div>
      <button class="exchange-btn" onclick="openExchange(${g.id}, '${escapeHtml(g.goods_name || '')}', ${g.points_price || 0}, ${g.stock || 0}, '${escapeHtml(g.goods_image || '')}')">立即兑换</button>
    </div>
  `;
  card.onclick = function(e) {
    if (e.target.tagName !== 'BUTTON') {
      location.href = `points_mall_detail.html?id=${g.id}`;
    }
  };
  listEl.appendChild(card);
}

// ============ 兑换弹窗 ============
function openExchange(id, name, points, stock, image) {
  if (!token) { showToast('请先登录'); return; }
  if (stock <= 0) { showToast('该商品已兑完'); return; }

  currentGoods = { id, name, points, stock, image };

  document.getElementById('sheetName').textContent = name;
  document.getElementById('sheetPoints').textContent = points.toLocaleString();
  document.getElementById('sheetStock').textContent = `剩余 ${stock} 件`;
  document.getElementById('formTip').textContent = `需消耗 ${points.toLocaleString()} 积分，当前可用积分：${document.getElementById('myPoints').textContent}`;

  let imgEl = document.getElementById('sheetImg');
  if (image) {
    imgEl.innerHTML = `<img src="${image}" style="width:100%;height:100%;object-fit:cover;border-radius:8px" onerror="this.parentElement.innerHTML='&#127873;'">`;
  }

  document.getElementById('mask').classList.add('show');
  document.getElementById('exchangeSheet').classList.add('show');
}

function closeSheet() {
  document.getElementById('mask').classList.remove('show');
  document.getElementById('exchangeSheet').classList.remove('show');
}

async function doExchange() {
  const btn = document.getElementById('confirmBtn');
  const name = document.getElementById('inputName').value.trim();
  const phone = document.getElementById('inputPhone').value.trim();
  const address = document.getElementById('inputAddress').value.trim();

  if (!name) { showToast('请填写收货人姓名'); return; }
  if (!/^1[3-9]\d{9}$/.test(phone)) { showToast('请填写正确的手机号'); return; }
  if (!address) { showToast('请填写收货地址'); return; }

  btn.disabled = true;
  btn.textContent = '兑换中...';

  try {
    const resp = await fetch(`${API_BASE}/points-mall/exchange?access_token=${token}`, {
      method: 'POST',
      headers: getHeaders(),
      body: JSON.stringify({
        goods_id: currentGoods.id,
        quantity: 1,
        address_snapshot: `${name} ${phone} ${address}`,
        phone: phone
      })
    });
    const json = await resp.json();
    if (json.success) {
      showToast('兑换成功！');
      closeSheet();
      loadMyPoints();
      loadGoods();
    } else {
      showToast(json.msg || '兑换失败');
    }
  } catch(e) {
    showToast('兑换失败，请稍后重试');
  } finally {
    btn.disabled = false;
    btn.textContent = '确认兑换';
  }
}

// ============ 工具 ============
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

function escapeHtml(str) {
  return str.replace(/'/g, "\\'").replace(/"/g, '\\"');
}

// 无限滚动
let sentinel = null;
const observer = new IntersectionObserver((entries) => {
  if (entries[0].isIntersecting && !loading) loadGoods();
}, { threshold: 0.1 });

// 创建sentinel元素用于滚动触发
function createSentinel() {
  const s = document.createElement('div');
  s.id = 'sentinel';
  s.style.height = '1px';
  document.getElementById('goodsList').appendChild(s);
  observer.observe(s);
}
setTimeout(createSentinel, 500);
</script>
</body>
</html>
