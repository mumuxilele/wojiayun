<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>商品管理 - 管理后台</title>
    <link rel="stylesheet" href="../business-common/list-style.css">
    <style>
        /* 页面特有样式 */
        .layout { display: flex; min-height: 100vh; }
        .sidebar { width: 200px; background: #2c3e50; min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 100; overflow-y: auto; }
        .sidebar-header { padding: 16px 20px; border-bottom: 1px solid #3d4f5f; }
        .sidebar-header h5 { color: white; font-size: 16px; font-weight: 600; }
        .sidebar a { color: #ecf0f1; text-decoration: none; padding: 12px 20px; display: block; font-size: 14px; transition: all .2s; }
        .sidebar a:hover { background: #34495e; }
        .sidebar a.active { background: #34495e; border-left: 3px solid var(--el-color-primary); }
        .main { flex: 1; margin-left: 200px; background: #f0f2f5; min-height: 100vh; }
        .prod-img { width: 44px; height: 44px; object-fit: cover; border-radius: 6px; border: 1px solid #f0f0f0; }
        .prod-img-placeholder { width: 44px; height: 44px; border-radius: 6px; background: #f5f5f5; display: inline-flex; align-items: center; justify-content: center; font-size: 20px; }
        .actions .link { color: var(--el-color-primary); cursor: pointer; margin-right: 10px; }
        .actions .link:hover { text-decoration: underline; }
        .actions .link.danger { color: var(--el-color-danger); }
        /* 弹窗 */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.5); z-index: 300; align-items: center; justify-content: center; }
        .modal-overlay.show { display: flex; }
        .modal { background: white; border-radius: 8px; padding: 24px; width: 560px; max-width: 95vw; max-height: 85vh; overflow-y: auto; }
        .modal-title { font-size: 16px; font-weight: 600; color: var(--el-text-primary); margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
        .form-row.full { grid-template-columns: 1fr; }
        .form-group label { display: block; font-size: 13px; color: var(--el-text-regular); margin-bottom: 5px; }
        .form-group label.required::before { content: '* '; color: var(--el-color-danger); }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%; padding: 8px 10px; border: 1px solid var(--el-border-color); border-radius: 4px;
            font-size: 13px; transition: border .2s; outline: none;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--el-color-primary); }
        .modal-footer { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--el-border-color-light); }
    </style>
</head>
<body class="wy-design-list">
<div class="layout">
    <div class="sidebar">
        <div class="sidebar-header"><h5>管理后台</h5></div>
        <a href="index.html">🏠 首页</a>
        <a href="statistics.html">📊 数据统计</a>
        <a href="venues.html">🏟️ 场地管理</a>
        <a href="shops.html">🏪 门店管理</a>
        <a href="products.html" class="active">📦 商品管理</a>
        <a href="applications.html">📋 申请单</a>
        <a href="orders.html">🧾 订单管理</a>
        <a href="points.html">💎 积分管理</a>
        <a href="coupons.html">🎫 优惠券</a>
        <a href="users.html">👥 用户管理</a>
        <a href="notices.html">📢 公告管理</a>
        <a href="feedback.html">💬 意见反馈</a>
    </div>
    <div class="main">
        <!-- 顶部区域 -->
        <div class="wy-design-list_top">
            <div class="wy-design-list_top_title">
                <h1 class="wy-design-list_title">📦 商品管理</h1>
                <div class="wy-design-list_space"></div>
                <div class="wy-design-list_btn-group">
                    <div class="wy-design-list_btn">
                        <button type="button" class="el-button el-button--primary el-button--small" onclick="openAddModal()">
                            <span>+ 新增商品</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 筛选区域 -->
        <div class="wy-design-list_filter">
            <div class="wy-design-list_other">
                <div class="el-input el-input--small" style="width: 200px;">
                    <input type="text" id="searchKw" placeholder="商品名称/描述搜索" onkeyup="if(event.key==='Enter') loadList()" class="el-input__inner">
                </div>
            </div>
            <div class="wy-design-list_other">
                <select id="filterShop" onchange="loadList()" class="el-input__inner" style="width: 140px;">
                    <option value="">所有门店</option>
                </select>
            </div>
            <div class="wy-design-list_other">
                <select id="filterCategory" onchange="loadList()" class="el-input__inner" style="width: 120px;">
                    <option value="">所有分类</option>
                </select>
            </div>
            <div class="wy-design-list_other">
                <select id="filterStatus" onchange="loadList()" class="el-input__inner" style="width: 100px;">
                    <option value="">全部状态</option>
                    <option value="active">上架</option>
                    <option value="inactive">下架</option>
                </select>
            </div>
            <div class="wy-design-list_btn-group">
                <div class="wy-design-list_btn">
                    <button type="button" class="el-button el-button--primary el-button--small" onclick="loadList()">
                        <span>搜索</span>
                    </button>
                </div>
                <div class="wy-design-list_btn">
                    <button type="button" class="el-button el-button--small" onclick="clearFilters()">
                        <span>清空</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 表格区域 -->
        <div class="wy-design-table wy-design-table_main wy-design-table_has-bar" style="margin: 16px 24px;">
            <div class="wy-design-table_bar">
                <i class="wy-design-table_set el-icon-setting" title="列设置"></i>
                <span class="wy-design-table_total">共 <em id="totalCount">0</em> 条</span>
                <div class="wy-pages">
                    <div class="wy-pages_prev el-icon-arrow-left" id="prevBtn" onclick="changePage(-1)"></div>
                    <div class="wy-pages_next el-icon-arrow-right" id="nextBtn" onclick="changePage(1)"></div>
                </div>
            </div>
            <div id="tableContent"><div style="text-align: center; padding: 60px; color: var(--el-text-secondary);">加载中...</div></div>
        </div>
    </div>
</div>

<!-- 新增/编辑弹窗 -->
<div class="modal-overlay" id="formModal" onclick="handleOverlayClick(event)">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-title"><span id="modalTitle">新增商品</span><span style="cursor:pointer;color:#999" onclick="closeModal()">✕</span></div>
        <input type="hidden" id="editId">
        <div class="form-row">
            <div class="form-group">
                <label class="required">商品名称</label>
                <input type="text" id="productName" placeholder="请输入商品名称" maxlength="100">
            </div>
            <div class="form-group">
                <label class="required">所属门店</label>
                <select id="productShop"><option value="">请选择门店</option></select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="required">价格（元）</label>
                <input type="number" id="productPrice" placeholder="0.00" min="0" step="0.01">
            </div>
            <div class="form-group">
                <label>原价（元）</label>
                <input type="number" id="productOriginalPrice" placeholder="0.00" min="0" step="0.01">
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>商品分类</label>
                <input type="text" id="productCategory" placeholder="如：生鲜/日用品/服装">
            </div>
            <div class="form-group">
                <label>库存数量</label>
                <input type="number" id="productStock" placeholder="0" min="0">
            </div>
        </div>
        <div class="form-row full">
            <div class="form-group">
                <label>商品描述</label>
                <textarea id="productDesc" rows="3" placeholder="请输入商品描述"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="el-button el-button--small" onclick="closeModal()">取消</button>
            <button type="button" class="el-button el-button--primary el-button--small" onclick="submitForm()">保存</button>
        </div>
    </div>
</div>

<script>
const token = localStorage.getItem('admin_token') || new URLSearchParams(location.search).get('access_token') || '';
const isdev = new URLSearchParams(location.search).get('isdev') || '0';
let currentPage = 1;
let totalPages = 1;

function authUrl(url) {
    const sep = url.includes('?') ? '&' : '?';
    return url + sep + 'access_token=' + encodeURIComponent(token) + '&isdev=' + isdev;
}

async function loadList(page) {
    currentPage = page || 1;
    const kw = document.getElementById('searchKw').value;
    const shopId = document.getElementById('filterShop').value;
    const category = document.getElementById('filterCategory').value;
    const status = document.getElementById('filterStatus').value;

    let url = '/api/admin/products?page=' + currentPage + '&page_size=20';
    if (kw) url += '&keyword=' + encodeURIComponent(kw);
    if (shopId) url += '&shop_id=' + shopId;
    if (category) url += '&category=' + encodeURIComponent(category);
    if (status) url += '&status=' + status;

    try {
        const res = await fetch(authUrl(url));
        const data = await res.json();
        if (data.success && data.data) {
            const total = data.data.total || 0;
            totalPages = Math.ceil(total / 20) || 1;
            document.getElementById('totalCount').textContent = total;
            document.getElementById('prevBtn').classList.toggle('disabled', currentPage <= 1);
            document.getElementById('nextBtn').classList.toggle('disabled', currentPage >= totalPages);

            const items = data.data.items || [];
            if (items.length === 0) {
                document.getElementById('tableContent').innerHTML = '<div style="text-align: center; padding: 60px; color: var(--el-text-secondary);">暂无数据</div>';
                return;
            }
            let html = `<table class="el-table el-table--fit el-table--border el-table--enable-row-hover">
                <thead class="el-table__header">
                    <tr>
                        <th><div class="cell">商品</div></th>
                        <th><div class="cell">价格</div></th>
                        <th><div class="cell">库存</div></th>
                        <th><div class="cell">分类</div></th>
                        <th><div class="cell">门店</div></th>
                        <th><div class="cell">状态</div></th>
                        <th><div class="cell">操作</div></th>
                    </tr>
                </thead>
                <tbody class="el-table__body">`;
            html += items.map(item => {
                const img = item.images ? `<img src="${item.images[0]}" class="prod-img">` : '<div class="prod-img-placeholder">📦</div>';
                const statusTag = item.status === 'active'
                    ? '<span class="el-tag el-tag--success el-tag--small">上架</span>'
                    : '<span class="el-tag el-tag--info el-tag--small">下架</span>';
                return `<tr>
                    <td><div class="cell" style="display:flex;align-items:center;gap:8px">${img}<span>${item.product_name || '-'}</span></div></td>
                    <td><div class="cell">¥${parseFloat(item.price || 0).toFixed(2)}</div></td>
                    <td><div class="cell">${item.stock || 0}</div></td>
                    <td><div class="cell">${item.category_name || '-'}</div></td>
                    <td><div class="cell">${item.shop_name || '-'}</div></td>
                    <td><div class="cell">${statusTag}</div></td>
                    <td><div class="cell actions">
                        <a class="link" onclick="openEditModal(${item.id})">编辑</a>
                        <a class="link danger" onclick="deleteProduct(${item.id})">删除</a>
                    </div></td>
                </tr>`;
            }).join('');
            html += '</tbody></table>';
            document.getElementById('tableContent').innerHTML = html;
        }
    } catch (e) {
        document.getElementById('tableContent').innerHTML = '<div style="text-align: center; padding: 60px; color: var(--el-text-secondary);">加载失败</div>';
    }
}

function changePage(delta) { loadList(currentPage + delta); }
function clearFilters() {
    document.getElementById('searchKw').value = '';
    document.getElementById('filterShop').value = '';
    document.getElementById('filterCategory').value = '';
    document.getElementById('filterStatus').value = '';
    loadList(1);
}

// 加载门店和分类下拉框
async function loadFilters() {
    try {
        const [shopRes, catRes] = await Promise.all([
            fetch(authUrl('/api/admin/shops?page=1&page_size=100')),
            fetch(authUrl('/api/admin/categories'))
        ]);
        const shopData = await shopRes.json();
        const catData = await catRes.json();

        if (shopData.success && shopData.data) {
            const shopSelects = [document.getElementById('filterShop'), document.getElementById('productShop')];
            const options = shopData.data.items?.map(s => `<option value="${s.id}">${s.shop_name}</option>`).join('') || '';
            shopSelects.forEach(s => { if(s) s.innerHTML += options; });
        }
        if (catData.success && catData.data) {
            const catSelect = document.getElementById('filterCategory');
            catSelect.innerHTML += catData.data.map(c => `<option value="${c.name}">${c.name}</option>`).join('');
        }
    } catch (e) {}
}

// 弹窗操作
function openAddModal() {
    document.getElementById('editId').value = '';
    document.getElementById('modalTitle').textContent = '新增商品';
    document.getElementById('productName').value = '';
    document.getElementById('productPrice').value = '';
    document.getElementById('productOriginalPrice').value = '';
    document.getElementById('productStock').value = '';
    document.getElementById('productCategory').value = '';
    document.getElementById('productDesc').value = '';
    document.getElementById('productShop').value = '';
    document.getElementById('formModal').classList.add('show');
}

function openEditModal(id) {
    document.getElementById('editId').value = id;
    document.getElementById('modalTitle').textContent = '编辑商品';
    fetch(authUrl('/api/admin/products/' + id))
        .then(r => r.json())
        .then(data => {
            if (data.success && data.data) {
                const p = data.data;
                document.getElementById('productName').value = p.product_name || '';
                document.getElementById('productPrice').value = p.price || '';
                document.getElementById('productOriginalPrice').value = p.original_price || '';
                document.getElementById('productStock').value = p.stock || '';
                document.getElementById('productCategory').value = p.category_name || '';
                document.getElementById('productDesc').value = p.description || '';
                document.getElementById('productShop').value = p.shop_id || '';
                document.getElementById('formModal').classList.add('show');
            }
        });
}

function closeModal() {
    document.getElementById('formModal').classList.remove('show');
}

function handleOverlayClick(e) {
    if (e.target === document.getElementById('formModal')) closeModal();
}

async function submitForm() {
    const id = document.getElementById('editId').value;
    const body = {
        product_name: document.getElementById('productName').value.trim(),
        price: parseFloat(document.getElementById('productPrice').value) || 0,
        original_price: parseFloat(document.getElementById('productOriginalPrice').value) || 0,
        stock: parseInt(document.getElementById('productStock').value) || 0,
        category_name: document.getElementById('productCategory').value.trim(),
        description: document.getElementById('productDesc').value.trim(),
        shop_id: document.getElementById('productShop').value
    };
    if (!body.product_name) { alert('请输入商品名称'); return; }
    if (!body.shop_id) { alert('请选择所属门店'); return; }

    const url = id ? '/api/admin/products/' + id : '/api/admin/products';
    const method = id ? 'PUT' : 'POST';
    try {
        const res = await fetch(authUrl(url), {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.success) { closeModal(); loadList(currentPage); }
        else { alert(data.msg || '保存失败'); }
    } catch (e) { alert('保存失败'); }
}

async function deleteProduct(id) {
    if (!confirm('确定要删除该商品吗？')) return;
    try {
        const res = await fetch(authUrl('/api/admin/products/' + id), { method: 'DELETE' });
        const data = await res.json();
        if (data.success) { loadList(currentPage); }
        else { alert(data.msg || '删除失败'); }
    } catch (e) { alert('删除失败'); }
}

loadFilters();
loadList(1);
</script>
</body>
</html>
