<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>订单管理</title>
    <link rel="stylesheet" href="../business-common/list-style.css">
    <style>
        /* 页面特有样式 */
        .amount { color: #f56c6c; font-weight: 600; }
        .actions .link { margin-right: 10px; }
        /* 弹窗样式 */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.45); z-index: 200; }
        .modal { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); background: var(--el-bg-white); border-radius: 4px; width: 580px; max-width: 95vw; max-height: 85vh; flex-direction: column; z-index: 201; box-shadow: 0 4px 20px rgba(0,0,0,.18); }
        .modal.show { display: flex; }
        .modal-header { padding: 16px 20px; border-bottom: 1px solid var(--el-border-color-light); display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
        .modal-title { font-size: 16px; font-weight: 600; color: var(--el-text-primary); }
        .modal-close { background: none; border: none; width: 32px; height: 32px; border-radius: 4px; cursor: pointer; font-size: 16px; color: var(--el-text-secondary); display: flex; align-items: center; justify-content: center; }
        .modal-close:hover { background: var(--el-bg-light); }
        .modal-body { padding: 20px; overflow-y: auto; flex: 1; }
        .modal-footer { padding: 12px 20px; border-top: 1px solid var(--el-border-color-light); display: flex; justify-content: flex-end; gap: 10px; flex-shrink: 0; }
        .detail-row { display: flex; margin-bottom: 12px; line-height: 1.6; }
        .detail-label { color: var(--el-text-secondary); min-width: 90px; flex-shrink: 0; }
        .detail-value { color: var(--el-text-primary); flex: 1; }
        .form-item { margin-bottom: 16px; }
        .form-label { font-size: 13px; color: var(--el-text-secondary); margin-bottom: 6px; display: block; }
        .form-select { width: 100%; padding: 8px 12px; border: 1px solid var(--el-border-color); border-radius: 4px; font-size: 14px; outline: none; }
        .form-select:focus { border-color: var(--el-color-primary); }
    </style>
</head>
<body class="wy-design-list">
    <!-- 顶部区域 -->
    <div class="wy-design-list_top">
        <div class="wy-design-list_top_title">
            <h1 class="wy-design-list_title">🧾 订单管理</h1>
            <div class="wy-design-list_space"></div>
            <div class="wy-design-list_btn-group">
                <div class="wy-design-list_btn">
                    <button type="button" class="el-button el-button--primary el-button--small" onclick="loadList(1)">
                        <span>搜索</span>
                    </button>
                </div>
                <div class="wy-design-list_btn">
                    <button type="button" class="el-button el-button--small" onclick="resetSearch()">
                        <span>重置</span>
                    </button>
                </div>
                <div class="wy-design-list_btn">
                    <button type="button" class="el-button el-button--small" onclick="exportOrders()">
                        <span>📥 导出CSV</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 筛选区域 -->
    <div class="wy-design-list_filter">
        <div class="wy-design-list_other">
            <div class="el-input el-input--small" style="width: 200px;">
                <input type="text" id="keyword" placeholder="搜索订单号/用户名/手机" class="el-input__inner">
            </div>
        </div>
        <div class="wy-design-list_other">
            <div class="el-select">
                <select id="statusFilter" class="el-input__inner" style="width: 140px;">
                    <option value="">全部订单状态</option>
                    <option value="pending">待支付</option>
                    <option value="paid">已支付</option>
                    <option value="processing">处理中</option>
                    <option value="completed">已完成</option>
                    <option value="cancelled">已取消</option>
                </select>
            </div>
        </div>
        <div class="wy-design-list_other">
            <div class="el-select">
                <select id="payStatusFilter" class="el-input__inner" style="width: 140px;">
                    <option value="">全部支付状态</option>
                    <option value="unpaid">未支付</option>
                    <option value="paid">已支付</option>
                    <option value="refunded">已退款</option>
                </select>
            </div>
        </div>
    </div>

    <!-- 表格区域 -->
    <div class="wy-design-table wy-design-table_main wy-design-table_has-bar">
        <div class="wy-design-table_bar">
            <i class="wy-design-table_set el-icon-setting" title="列设置"></i>
            <span class="wy-design-table_total">已选择 <em>0</em> 个</span>
            <div class="wy-pages">
                <div class="wy-pages_total">共<em id="totalCount">0</em>条/<em id="totalPages">0</em>页</div>
                <div class="wy-pages_prev el-icon-arrow-left" id="prevBtn" onclick="changePage(-1)"></div>
                <div class="wy-pages_next el-icon-arrow-right" id="nextBtn" onclick="changePage(1)"></div>
            </div>
        </div>
        <table class="el-table el-table--fit el-table--border el-table--enable-row-hover">
            <thead class="el-table__header">
                <tr>
                    <th><div class="cell">订单号</div></th>
                    <th><div class="cell">类型</div></th>
                    <th><div class="cell">用户</div></th>
                    <th><div class="cell">总金额</div></th>
                    <th><div class="cell">实付金额</div></th>
                    <th><div class="cell">支付状态</div></th>
                    <th><div class="cell">订单状态</div></th>
                    <th><div class="cell">创建时间</div></th>
                    <th><div class="cell">操作</div></th>
                </tr>
            </thead>
            <tbody class="el-table__body" id="listBody">
                <tr><td colspan="9" style="text-align: center; padding: 60px; color: var(--el-text-secondary);">加载中...</td></tr>
            </tbody>
        </table>
    </div>

    <!-- 查看详情弹窗 -->
    <div class="modal-overlay" id="viewOverlay" onclick="if(event.target===this)closeView()"></div>
    <div class="modal" id="viewModal">
        <div class="modal-header">
            <span class="modal-title">订单详情</span>
            <button class="modal-close" onclick="closeView()">✕</button>
        </div>
        <div class="modal-body" id="viewBody">加载中...</div>
        <div class="modal-footer">
            <button class="el-button el-button--small" onclick="closeView()">关闭</button>
            <button class="el-button el-button--primary el-button--small" id="viewEditBtn" onclick="openEditFromView()">修改状态</button>
        </div>
    </div>

    <!-- 编辑订单状态弹窗 -->
    <div class="modal-overlay" id="editOverlay" onclick="if(event.target===this)closeEdit()"></div>
    <div class="modal" id="editModal">
        <div class="modal-header">
            <span class="modal-title" id="editModalTitle">修改订单状态</span>
            <button class="modal-close" onclick="closeEdit()">✕</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="editOrderId">
            <div class="form-item">
                <label class="form-label">订单状态</label>
                <select class="form-select" id="editStatus">
                    <option value="pending">待支付</option>
                    <option value="paid">已支付</option>
                    <option value="processing">处理中</option>
                    <option value="completed">已完成</option>
                    <option value="cancelled">已取消</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="el-button el-button--small" onclick="closeEdit()">取消</button>
            <button class="el-button el-button--primary el-button--small" onclick="submitEdit()">确认保存</button>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('admin_token') || new URLSearchParams(location.search).get('access_token') || '';
        const isdev = new URLSearchParams(location.search).get('isdev') || '0';
        let currentPage = 1;
        let totalPages = 1;
        let currentViewId = null;

        const PAY_STATUS_MAP = { pending: '待支付', paid: '已支付', refunded: '已退款' };
        const PAY_STATUS_TAG = { pending: 'warning', paid: 'success', refunded: 'info' };
        const STATUS_MAP = { pending: '待支付', paid: '已支付', processing: '处理中', completed: '已完成', cancelled: '已取消' };
        const STATUS_TAG = { pending: 'warning', paid: 'success', processing: 'primary', completed: 'success', cancelled: 'info' };
        const ORDER_TYPE_MAP = { venue: '场地预约', service: '服务', product: '商品', other: '其他' };

        function authUrl(url) {
            const sep = url.includes('?') ? '&' : '?';
            return url + sep + 'access_token=' + encodeURIComponent(token) + '&isdev=' + isdev;
        }

        async function loadList(page) {
            currentPage = page || 1;
            const keyword = document.getElementById('keyword').value;
            const status = document.getElementById('statusFilter').value;
            const payStatus = document.getElementById('payStatusFilter').value;
            let url = '/api/admin/orders?page=' + currentPage + '&page_size=20';
            if (keyword) url += '&keyword=' + encodeURIComponent(keyword);
            if (status) url += '&status=' + status;
            if (payStatus) url += '&pay_status=' + payStatus;
            try {
                const res = await fetch(authUrl(url));
                const data = await res.json();
                if (data.success && data.data) {
                    const total = data.data.total || 0;
                    totalPages = Math.ceil(total / 20) || 1;
                    document.getElementById('totalCount').textContent = total;
                    document.getElementById('totalPages').textContent = totalPages;
                    document.getElementById('prevBtn').classList.toggle('disabled', currentPage <= 1);
                    document.getElementById('nextBtn').classList.toggle('disabled', currentPage >= totalPages);

                    const items = data.data.items || [];
                    if (items.length === 0) {
                        document.getElementById('listBody').innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 60px; color: var(--el-text-secondary);">暂无数据</td></tr>';
                        return;
                    }
                    document.getElementById('listBody').innerHTML = items.map(item =>
                        `<tr>
                            <td><div class="cell" style="font-family:monospace;font-size:12px">${item.order_no || '-'}</div></td>
                            <td><div class="cell">${ORDER_TYPE_MAP[item.order_type] || item.order_type || '-'}</div></td>
                            <td><div class="cell">${item.user_name || '-'}<br><span style="color:var(--el-text-secondary);font-size:12px">${item.user_phone || ''}</span></div></td>
                            <td><div class="cell amount">¥${parseFloat(item.total_amount || 0).toFixed(2)}</div></td>
                            <td><div class="cell amount">¥${parseFloat(item.actual_amount || 0).toFixed(2)}</div></td>
                            <td><div class="cell"><span class="el-tag el-tag--${PAY_STATUS_TAG[item.pay_status] || 'info'} el-tag--small">${PAY_STATUS_MAP[item.pay_status] || item.pay_status || '-'}</span></div></td>
                            <td><div class="cell"><span class="el-tag el-tag--${STATUS_TAG[item.order_status] || 'info'} el-tag--small">${STATUS_MAP[item.order_status] || item.order_status || '-'}</span></div></td>
                            <td><div class="cell">${(item.created_at || '').substring(0, 16) || '-'}</div></td>
                            <td><div class="cell actions">
                                <a class="link" onclick="viewOrder(${item.id})">查看</a>
                                <a class="link" onclick="openEdit(${item.id}, '${item.order_no || ''}', '${item.order_status || ''}')">修改状态</a>
                            </div></td>
                        </tr>`
                    ).join('');
                }
            } catch (e) {
                document.getElementById('listBody').innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 60px; color: var(--el-text-secondary);">加载失败</td></tr>';
            }
        }

        function changePage(delta) { loadList(currentPage + delta); }
        function resetSearch() {
            document.getElementById('keyword').value = '';
            document.getElementById('statusFilter').value = '';
            document.getElementById('payStatusFilter').value = '';
            loadList(1);
        }

        function exportOrders() {
            const status = document.getElementById('statusFilter').value;
            const payStatus = document.getElementById('payStatusFilter').value;
            const keyword = document.getElementById('keyword').value;
            let url = authUrl('/api/admin/export/orders');
            if (status) url += '&status=' + status;
            if (payStatus) url += '&pay_status=' + payStatus;
            if (keyword) url += '&keyword=' + encodeURIComponent(keyword);
            window.open(url, '_blank');
        }

        // ========== 查看详情 ==========
        async function viewOrder(id) {
            currentViewId = id;
            document.getElementById('viewBody').innerHTML = '<div style="text-align:center;padding:30px;color:#909399">加载中...</div>';
            document.getElementById('viewOverlay').style.display = 'block';
            document.getElementById('viewModal').classList.add('show');
            try {
                const res = await fetch(authUrl('/api/admin/orders/' + id));
                const data = await res.json();
                if (!data.success || !data.data) {
                    document.getElementById('viewBody').innerHTML = '<div style="text-align:center;padding:30px;color:#f00">获取详情失败</div>';
                    return;
                }
                const item = data.data;
                document.getElementById('viewBody').innerHTML = `
                    <div class="detail-row"><span class="detail-label">订单号</span><span class="detail-value" style="font-family:monospace">${item.order_no || '-'}</span></div>
                    <div class="detail-row"><span class="detail-label">订单类型</span><span class="detail-value">${ORDER_TYPE_MAP[item.order_type] || item.order_type || '-'}</span></div>
                    <div class="detail-row"><span class="detail-label">用户</span><span class="detail-value">${item.user_name || '-'}</span></div>
                    <div class="detail-row"><span class="detail-label">手机号</span><span class="detail-value">${item.user_phone || '-'}</span></div>
                    <div class="detail-row"><span class="detail-label">总金额</span><span class="detail-value amount">¥${parseFloat(item.total_amount || 0).toFixed(2)}</span></div>
                    <div class="detail-row"><span class="detail-label">实付金额</span><span class="detail-value amount">¥${parseFloat(item.actual_amount || 0).toFixed(2)}</span></div>
                    <div class="detail-row"><span class="detail-label">支付状态</span><span class="detail-value"><span class="el-tag el-tag--${PAY_STATUS_TAG[item.pay_status]||'info'} el-tag--small">${PAY_STATUS_MAP[item.pay_status]||item.pay_status||'-'}</span></span></div>
                    <div class="detail-row"><span class="detail-label">订单状态</span><span class="detail-value"><span class="el-tag el-tag--${STATUS_TAG[item.order_status]||'info'} el-tag--small">${STATUS_MAP[item.order_status]||item.order_status||'-'}</span></span></div>
                    <div class="detail-row"><span class="detail-label">备注</span><span class="detail-value">${item.remark || '-'}</span></div>
                    <div class="detail-row"><span class="detail-label">创建时间</span><span class="detail-value">${item.created_at || '-'}</span></div>
                    <div class="detail-row"><span class="detail-label">更新时间</span><span class="detail-value">${item.updated_at || '-'}</span></div>`;
            } catch (e) {
                document.getElementById('viewBody').innerHTML = '<div style="text-align:center;padding:30px;color:#f00">加载失败</div>';
            }
        }

        function closeView() {
            document.getElementById('viewOverlay').style.display = 'none';
            document.getElementById('viewModal').classList.remove('show');
        }

        function openEditFromView() {
            closeView();
            openEdit(currentViewId, '', '');
        }

        // ========== 修改订单状态 ==========
        function openEdit(id, orderNo, currentStatus) {
            document.getElementById('editOrderId').value = id;
            document.getElementById('editModalTitle').textContent = '修改订单状态' + (orderNo ? ' - ' + orderNo : '');
            document.getElementById('editStatus').value = currentStatus || 'pending';
            document.getElementById('editOverlay').style.display = 'block';
            document.getElementById('editModal').classList.add('show');
        }

        function closeEdit() {
            document.getElementById('editOverlay').style.display = 'none';
            document.getElementById('editModal').classList.remove('show');
        }

        async function submitEdit() {
            const id = document.getElementById('editOrderId').value;
            const status = document.getElementById('editStatus').value;
            try {
                const res = await fetch(authUrl('/api/admin/orders/' + id), {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ order_status: status })
                });
                const data = await res.json();
                if (data.success) { alert('更新成功'); closeEdit(); loadList(currentPage); }
                else { alert(data.msg || '操作失败'); }
            } catch (e) { alert('操作失败'); }
        }

        // Enter 搜索
        document.getElementById('keyword').addEventListener('keydown', e => { if (e.key === 'Enter') loadList(1); });

        loadList(1);
    </script>
</body>
</html>
